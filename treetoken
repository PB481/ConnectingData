    name: str
    location: str
    hectares: float
    species_mix: str
    planting_year: int
    tenor_years: int
    baseline_tco2e: float               # Carbon stock at origination
    expected_annual_seq: float          # tCO2e/ha/year expected sequestration
    landowner: str
