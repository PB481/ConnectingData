def new_tx_id():
    tx = f"TX-{st.session_state.next_tx:06d}"
    st.session_state.next_tx += 1
    return tx

def new_order_id():
    oid = f"ORD-{st.session_state.next_order:06d}"
    st.session_state.next_order += 1
    return oid

def record_ledger(event_type, project_id, actor, counterparty, token_type,
                  amount, price_eur, metadata):
    entry = LedgerEntry(
        tx_id=new_tx_id(),
        timestamp=datetime.now(timezone.utc).isoformat() + "Z",
        event_type=event_type,
        project_id=project_id,
        actor=actor,
        counterparty=counterparty,
        token_type=token_type,
        amount=amount,
        price_eur=price_eur,
        metadata=metadata,
        block_hash=_hash({"e": event_type, "a": actor, "amt": amount, "t": datetime.now(timezone.utc).isoformat()}),
    )
    st.session_state.ledger.append(entry)
    return entry

def get_balance(actor, token_type, project_id):
    return st.session_state.balances.get((actor, token_type, project_id), 0)

def adjust_balance(actor, token_type, project_id, delta):
    key = (actor, token_type, project_id)
    st.session_state.balances[key] = st.session_state.balances.get(key, 0) + delta

def run_mrv_cycle(project_id, cycle_year, v1_reading, v2_reading, tolerance_pct):
    """Simulate dual-verifier MRV with oracle aggregation."""
    project = st.session_state.projects[project_id]

    v1_sig = _hash(f"verifier_sylvera_{cycle_year}_{v1_reading}")
    v2_sig = _hash(f"verifier_pachama_{cycle_year}_{v2_reading}")
    sat_hash = _hash(f"sentinel2_{project_id}_{cycle_year}")
    lidar_hash = _hash(f"lidar_{project_id}_{cycle_year}")

    # Oracle aggregation logic
    avg = (v1_reading + v2_reading) / 2
    divergence = abs(v1_reading - v2_reading) / avg if avg > 0 else 0

    if divergence > tolerance_pct / 100:
        status = "DISPUTED"
        agreed = None
    else:
        status = "AGREED"
        agreed = avg  # Conservative — could use min() for stricter policy

    cycle = MRVCycle(
        cycle_id=f"MRV-{project_id}-{cycle_year}",
        project_id=project_id,
        cycle_year=cycle_year,
        verifier_1="Sylvera (independent)",
        verifier_1_reading=v1_reading,
        verifier_1_signature=v1_sig,
        verifier_2="Pachama (independent)",
        verifier_2_reading=v2_reading,
        verifier_2_signature=v2_sig,
        satellite_data_hash=sat_hash,
        lidar_data_hash=lidar_hash,
        tolerance_pct=tolerance_pct,
        agreed_reading=agreed,
        status=status,
        timestamp=datetime.now(timezone.utc).isoformat() + "Z",
    )
    st.session_state.mrv_cycles.append(cycle)

    # If AGREED, mint CO2E to TREE holders pro-rata
    if status == "AGREED":
        total_tree = project.tree_tokens_issued
        # Find all TREE holders for this project
        for (actor, tok, pid), qty in list(st.session_state.balances.items()):
            if tok == "TREE" and pid == project_id and qty > 0:
                pro_rata_co2e = agreed * (qty / total_tree)
                # Apply 15% buffer pool withholding
                net_co2e = pro_rata_co2e * 0.85
                adjust_balance(actor, f"CO2E-{cycle_year}", project_id, net_co2e)
                record_ledger(
                    "MINT_CO2E",
                    project_id,
                    f"Oracle-{cycle_year}",
                    actor,
                    f"CO2E-{cycle_year}",
                    net_co2e,
                    st.session_state.current_co2e_spot,
                    {"vintage": cycle_year, "buffer_pool_pct": 15, "gross": pro_rata_co2e},
                )
        # Buffer pool
        buffer = agreed * 0.15
        adjust_balance("Buffer Pool (reinsurance)", f"CO2E-{cycle_year}", project_id, buffer)
        record_ledger("BUFFER_ALLOCATION", project_id, f"Oracle-{cycle_year}",
                      "Buffer Pool", f"CO2E-{cycle_year}", buffer, None,
                      {"purpose": "reversal_insurance"})

    return cycle


def place_order(project_id, token_type, side, quantity, price, actor):
    order = Order(
        order_id=new_order_id(),
        timestamp=datetime.now(timezone.utc).isoformat() + "Z",
        project_id=project_id,
        token_type=token_type,
        side=side,
        quantity=quantity,
        price_eur=price,
        actor=actor,
        status="OPEN",
    )
    st.session_state.orders.append(order)
    match_orders(project_id, token_type)
    return order


def match_orders(project_id, token_type):
    """Simple price-time priority matching."""
    buys = sorted(
        [o for o in st.session_state.orders
         if o.status == "OPEN" and o.side == "BUY"
         and o.project_id == project_id and o.token_type == token_type],
        key=lambda o: (-o.price_eur, o.timestamp)
    )
    sells = sorted(
        [o for o in st.session_state.orders
         if o.status == "OPEN" and o.side == "SELL"
         and o.project_id == project_id and o.token_type == token_type],
        key=lambda o: (o.price_eur, o.timestamp)
    )
    for b in buys:
        for s in sells:
            if b.status != "OPEN" or s.status != "OPEN":
                continue
            if b.price_eur >= s.price_eur:
                trade_qty = min(b.quantity, s.quantity)
                trade_price = s.price_eur  # Price-taker gets maker price

                # Atomic DvP: check balances
                seller_has = get_balance(s.actor, token_type, project_id)
                buyer_cash = st.session_state.cash.get(b.actor, 0)
                cost = trade_qty * trade_price

                if seller_has < trade_qty or buyer_cash < cost:
                    # Would happen in production via smart contract pre-check
                    continue

                # Execute atomic swap
                adjust_balance(s.actor, token_type, project_id, -trade_qty)
                adjust_balance(b.actor, token_type, project_id, trade_qty)
                st.session_state.cash[s.actor] = st.session_state.cash.get(s.actor, 0) + cost
                st.session_state.cash[b.actor] = st.session_state.cash.get(b.actor, 0) - cost

                record_ledger(
                    "TRADE",
                    project_id,
                    s.actor,
                    b.actor,
                    token_type,
                    trade_qty,
                    trade_price,
                    {"buy_order": b.order_id, "sell_order": s.order_id, "gross_eur": cost},
                )
                st.session_state.filled_trades.append({
                    "timestamp": datetime.now(timezone.utc).isoformat() + "Z",
                    "project": project_id, "token": token_type,
                    "buyer": b.actor, "seller": s.actor,
                    "qty": trade_qty, "price": trade_price, "value": cost,
                })

                b.quantity -= trade_qty
                s.quantity -= trade_qty
                if b.quantity == 0: b.status = "FILLED"
                if s.quantity == 0: s.status = "FILLED"

                # Update spot reference
                if token_type.startswith("CO2E"):
                    st.session_state.current_co2e_spot = trade_price


def retire_co2e(project_id, vintage_token, quantity, corporate, claim_description):
    """Burn CO2E tokens — corporate offset claim."""
    if get_balance(corporate, vintage_token, project_id) < quantity:
        return None

    adjust_balance(corporate, vintage_token, project_id, -quantity)

    cert_id = f"RET-{uuid.uuid4().hex[:8].upper()}"
    cert = {
        "certificate_id": cert_id,
        "corporate": corporate,
        "project_id": project_id,
        "vintage": vintage_token.replace("CO2E-", ""),
        "tco2e_retired": quantity,
        "claim_description": claim_description,
        "timestamp": datetime.now(timezone.utc).isoformat() + "Z",
        "cert_hash": _hash({"cert": cert_id, "corp": corporate, "qty": quantity}),
    }
    st.session_state.retirements.append(cert)

    record_ledger(
        "BURN_CO2E",
        project_id,
        corporate,
        "Retirement registry",
        vintage_token,
        quantity,
        st.session_state.current_co2e_spot,
        {"certificate": cert_id, "claim": claim_description},
    )
    return cert


