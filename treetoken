@dataclass
class Project:
    """A forestry origination — one SPV, one tokenisation event."""
    project_id: str
    name: str
    location: str
    hectares: float
    species_mix: str
    planting_year: int
    tenor_years: int
    baseline_tco2e: float               # Carbon stock at origination
    expected_annual_seq: float          # tCO2e/ha/year expected sequestration
    landowner: str
    tree_tokens_issued: int             # Total TREE supply for this project
    origination_price_eur: float        # Initial price per TREE
    gps_polygon_hash: str
    legal_opinion_hash: str
    created_at: str

@dataclass
class LedgerEntry:
    """Single event in the on-chain-equivalent ledger."""
    tx_id: str
    timestamp: str
    event_type: str    # MINT_TREE, MINT_CO2E, TRANSFER, BURN_CO2E, etc.
    project_id: str
    actor: str
    counterparty: Optional[str]
    token_type: str    # TREE or CO2E
    amount: float
    price_eur: Optional[float]
    metadata: dict
    block_hash: str

@dataclass
class Order:
    order_id: str
    timestamp: str
    project_id: str
    token_type: str   # TREE or CO2E
    side: str         # BUY or SELL
    quantity: float
    price_eur: float
    actor: str
    status: str       # OPEN, FILLED, PARTIAL, CANCELLED

@dataclass
class MRVCycle:
    cycle_id: str
    project_id: str
    cycle_year: int
    verifier_1: str
    verifier_1_reading: float   # tCO2e claimed sequestration
    verifier_1_signature: str
    verifier_2: str
    verifier_2_reading: float
    verifier_2_signature: str
    satellite_data_hash: str
    lidar_data_hash: str
    tolerance_pct: float
    agreed_reading: Optional[float]
    status: str                 # PENDING, AGREED, DISPUTED, PAUSED
    timestamp: str


