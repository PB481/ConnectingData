def _hash(obj) -> str:
    """Lightweight content hash to simulate on-chain commitments."""
    s = json.dumps(obj, sort_keys=True, default=str) if not isinstance(obj, str) else obj
    return hashlib.sha256(s.encode()).hexdigest()[:16]

