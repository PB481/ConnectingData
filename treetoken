def timber_growth_factor(years_elapsed: float, tenor: float, model: str) -> float:
    """
    Returns 0..1 representing % of mature timber value accumulated.
    Sigmoid reflects real forestry — slow early, fast mid-cycle, plateau late.
    """
    if years_elapsed <= 0:
        return 0.0
    if years_elapsed >= tenor:
        return 1.0
    if model == "Linear":
        return years_elapsed / tenor
    if model == "Empirical Irish":
        # Based on Teagasc native broadleaf yield curves (approximation)
        # Slow early because broadleaves establish gradually
        t = years_elapsed / tenor
        return min(1.0, t ** 1.4)
    # Sigmoid (default) — inflection at 0.6 of tenor (later than linear mid)
    # Reflects real forestry: slow early establishment, fast mid-cycle growth,
    # plateau as canopy closes
    t = years_elapsed / tenor
    k = 6.0          # steepness
    mid = 0.6        # inflection later than linear midpoint
    raw = 1 / (1 + np.exp(-k * (t - mid)))
    # Normalise endpoints to 0 and 1
    raw_0 = 1 / (1 + np.exp(-k * (0 - mid)))
    raw_1 = 1 / (1 + np.exp(-k * (1 - mid)))
    return float((raw - raw_0) / (raw_1 - raw_0))


def carbon_price_path(year_from_origination: int, tenor: int, assumptions: dict) -> float:
    """Forward curve for carbon price €/tCO2e at a given year."""
    curve = assumptions["carbon_price_curve"]
    start = assumptions["carbon_price_start"]
    if curve == "Flat":
        return start
    if curve == "Linear trend":
        end = assumptions["carbon_price_end"]
        if tenor <= 0:
            return start
        return start + (end - start) * (year_from_origination / tenor)
    return start


def calculate_nav(project, assumptions: dict, mrv_cycles: list,
                  retirements: list, current_year: int,
                  current_spot: float) -> dict:
    """
    Full NAV calculation with component decomposition and audit trail.
    Returns a dict with every intermediate number — this is the mark-to-model
    methodology that a fund administrator or depositary would need to validate.
    """
    tenor = project.tenor_years
    years_elapsed = current_year - project.planting_year
    years_remaining = max(tenor - years_elapsed, 0)

    # --- 1. LAND VALUE ---
    land_base = assumptions["land_value_per_ha"] * project.hectares
    land_appreciation = (1 + assumptions["land_appreciation_pct"] / 100) ** years_elapsed
    land_value = land_base * land_appreciation

    # --- 2. STANDING TIMBER VALUE ---
    mature_timber = assumptions["timber_yield_per_ha_at_maturity"] * project.hectares
    growth = timber_growth_factor(years_elapsed, tenor, assumptions["timber_growth_model"])
    timber_value = mature_timber * growth

    # --- 3. CARBON — REALISED (sequestered but not retired) ---
    agreed_cycles = [c for c in mrv_cycles if c.status == "AGREED"]
    total_sequestered = sum(c.agreed_reading for c in agreed_cycles)
    net_sequestered = total_sequestered * (1 - assumptions["buffer_coverage_ratio"])
    total_retired = sum(r["tco2e_retired"] for r in retirements)
    outstanding_co2e = max(net_sequestered - total_retired, 0)
    realised_carbon_value = outstanding_co2e * current_spot

    # --- 4. CARBON — FUTURE (projected, present-valued) ---
    expected_annual = project.expected_annual_seq * project.hectares
    future_carbon_pv = 0.0
    reversal_rate = assumptions["reversal_probability_pct"] / 100
    discount = assumptions["discount_rate_pct"] / 100
    for t in range(1, years_remaining + 1):
        year_index = years_elapsed + t
        price_t = carbon_price_path(year_index, tenor, assumptions)
        net_annual = expected_annual * (1 - assumptions["buffer_coverage_ratio"])
        gross_revenue = net_annual * price_t
        # Landowner share reduces investor revenue
        investor_share = gross_revenue * (1 - assumptions["landowner_carbon_share_pct"] / 100)
        # Probability adjustment for reversal
        survival = (1 - reversal_rate) ** t
        # Discount to PV
        pv = (investor_share * survival) / ((1 + discount) ** t)
        future_carbon_pv += pv

    # --- 5. OPERATING COSTS (future, discounted) ---
    annual_ops = (assumptions["management_cost_per_ha"]
                  + assumptions["mrv_cost_per_ha"]) * project.hectares
    ops_pv = sum(annual_ops / ((1 + discount) ** t) for t in range(1, years_remaining + 1))

    # --- 6. PLATFORM FEES (future, discounted) ---
    # Simple approximation — bps on gross carbon revenue
    fees_pv = future_carbon_pv * (assumptions["platform_fee_bps"] / 10_000) * years_remaining

    # --- 7. GROSS NAV ---
    gross_nav = land_value + timber_value + realised_carbon_value + future_carbon_pv
    net_nav = gross_nav - ops_pv - fees_pv
    nav_per_tree = net_nav / project.tree_tokens_issued if project.tree_tokens_issued else 0

    return {
        "land_value": land_value,
        "timber_value": timber_value,
        "realised_carbon_value": realised_carbon_value,
        "future_carbon_pv": future_carbon_pv,
        "ops_pv": ops_pv,
        "fees_pv": fees_pv,
        "gross_nav": gross_nav,
        "net_nav": net_nav,
        "nav_per_tree": nav_per_tree,
        "outstanding_co2e": outstanding_co2e,
        "total_sequestered": total_sequestered,
        "total_retired": total_retired,
        "years_elapsed": years_elapsed,
        "years_remaining": years_remaining,
        "timber_growth_pct": growth * 100,
        "assumptions_hash": _hash(assumptions),
        "calculation_timestamp": datetime.utcnow().isoformat() + "Z",
    }


def run_sensitivity(project, base_assumptions: dict, mrv_cycles: list,
                    retirements: list, current_year: int, current_spot: float,
                    variable: str, shock_pct: float) -> dict:
    """Returns NAV under ±shock for a single assumption variable."""
    shocked_up = dict(base_assumptions)
    shocked_down = dict(base_assumptions)

    if isinstance(base_assumptions[variable], (int, float)):
        shocked_up[variable] = base_assumptions[variable] * (1 + shock_pct / 100)
        shocked_down[variable] = base_assumptions[variable] * (1 - shock_pct / 100)

    nav_up = calculate_nav(project, shocked_up, mrv_cycles, retirements, current_year, current_spot)
    nav_down = calculate_nav(project, shocked_down, mrv_cycles, retirements, current_year, current_spot)

    return {
        "variable": variable,
        "shock_pct": shock_pct,
        "nav_up": nav_up["net_nav"],
        "nav_down": nav_down["net_nav"],
    }


