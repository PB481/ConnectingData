/* ============================================================================
   SLIDE 5 — TRADE-TO-NAV FLOW
   ============================================================================ */
let flowParticleHandle = null;
function drawFlow() {
  const svg = d3.select('#flow-svg');
  if (!svg.node()) return;
  const node = svg.node();
  const bbox = node.getBoundingClientRect();
  const W = bbox.width, H = bbox.height;
  if (!W || !H) return;
  svg.selectAll('*').remove();
  svg.attr('viewBox', `0 0 ${W} ${H}`);

  const padX = 40, padY = 30;
  const cols = d3.max(FLOW_NODES, n => n.col) + 1;
  const nodeW = 200, nodeH = 64;
  // distribute columns so first col left edge sits at padX, last col right edge sits at W - padX
  const colSpan = (W - padX * 2 - nodeW) / (cols - 1);

  // group nodes by column to compute y-offsets
  const byCol = d3.group(FLOW_NODES, d => d.col);
  const positions = {};
  byCol.forEach((arr, col) => {
    const total = arr.length;
    arr.forEach((n, i) => {
      const cy = padY + (H - padY * 2) * ((i + 0.5) / total);
      const x = padX + col * colSpan;
      positions[n.id] = { x, y: cy - nodeH / 2, cx: x + nodeW / 2, cy, node: n };
    });
  });

  // links — smooth bezier
  const linkG = svg.append('g');
  const linkPaths = [];
  FLOW_LINKS.forEach(link => {
    const s = positions[link.source], t = positions[link.target];
    if (!s || !t) return;
    const sx = s.x + nodeW, sy = s.cy;
    const tx = t.x, ty = t.cy;
    const mx = (sx + tx) / 2;
    const d = `M${sx},${sy} C${mx},${sy} ${mx},${ty} ${tx},${ty}`;
    const path = linkG.append('path')
      .attr('class', 'link')
      .attr('d', d)
      .attr('stroke-width', 12);
    linkPaths.push({ path: path.node(), s, t });
  });

  // nodes
  const nodeG = svg.append('g');
  Object.values(positions).forEach((p, i) => {
    const g = nodeG.append('g')
      .attr('transform', `translate(${p.x},${p.y})`)
      .style('opacity', 0);
    g.append('rect')
      .attr('class', 'node-rect' + (p.node.terminal ? ' terminal' : ''))
      .attr('width', nodeW).attr('height', nodeH)
      .attr('rx', 1);
    g.append('text')
      .attr('class', 'node-label')
      .attr('x', 16).attr('y', 26)
      .text(p.node.label);
    g.append('text')
      .attr('class', 'node-sub')
      .attr('x', 16).attr('y', 46)
      .text(p.node.sub);

    g.transition().delay(100 + i * 60).duration(400).style('opacity', 1);
  });

  // particles travelling along links
  if (flowParticleHandle) cancelAnimationFrame(flowParticleHandle);
  const particles = [];
  function spawn() {
    if (linkPaths.length === 0) return;
    const lp = linkPaths[Math.floor(Math.random() * linkPaths.length)];
    particles.push({ link: lp, t: 0, speed: 0.0025 + Math.random() * 0.003, r: 1.6 + Math.random() * 1.4 });
  }

  const particleLayer = svg.append('g');
  let last = performance.now();
  let spawnTimer = 0;
  function tick(now) {
    const dt = Math.min(50, now - last); last = now;
    spawnTimer += dt;
    if (spawnTimer > 90) { spawn(); if (Math.random() < 0.4) spawn(); spawnTimer = 0; }
    particleLayer.selectAll('circle').remove();
    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.t += p.speed * dt;
      if (p.t >= 1) { particles.splice(i, 1); continue; }
      const path = p.link.path;
      const len = path.getTotalLength();
      const pt = path.getPointAtLength(p.t * len);
      particleLayer.append('circle')
        .attr('class', 'particle')
        .attr('cx', pt.x).attr('cy', pt.y).attr('r', p.r)
        .style('fill-opacity', 0.85);
    }
    flowParticleHandle = requestAnimationFrame(tick);
  }
  flowParticleHandle = requestAnimationFrame(tick);
}
function stopFlowParticles() {
  if (flowParticleHandle) { cancelAnimationFrame(flowParticleHandle); flowParticleHandle = null; }
}

