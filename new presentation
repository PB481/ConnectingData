<style>
/* ============================================================================
   DESIGN TOKENS — edit these to retheme the entire deck
   ============================================================================ */
:root {
  /* Surfaces */
  --bg-deep:        #07090F;
  --bg:             #0A0E1A;
  --bg-elev-1:      #111623;
  --bg-elev-2:      #1A2033;
  --rule:           rgba(232, 234, 237, 0.08);
  --rule-strong:    rgba(232, 234, 237, 0.18);

  /* Ink */
  --ink:            #E8EAED;
  --ink-muted:      #9AA0AC;
  --ink-dim:        #5C6370;

  /* Accents */
  --gold:           #C9A961;
  --gold-soft:      #D9BE7E;
  --gold-deep:      #8C7236;
  --teal:           #4FB3BF;
  --teal-soft:      #7DCCD4;

  /* Semantic */
  --positive:       #6FCF97;
  --warning:        #E8B86B;
  --danger:         #E07A5F;

  /* Typography scale */
  --font-stack:     -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, "Helvetica Neue", Arial, sans-serif;
  --font-mono:      "SF Mono", Menlo, Consolas, "Roboto Mono", monospace;

  --fs-display:     clamp(56px, 8vw, 112px);
  --fs-h1:          clamp(40px, 5vw, 72px);
  --fs-h2:          clamp(28px, 3.2vw, 44px);
  --fs-h3:          22px;
  --fs-body:        20px;
  --fs-small:       15px;
  --fs-micro:       12px;

  /* Geometry */
  --radius:         2px;
  --gutter:         48px;
}

/* ============================================================================
   GLOBAL TYPOGRAPHY & RESET OVERRIDES
   ============================================================================ */
html, body { background: var(--bg); }
.reveal {
  font-family: var(--font-stack);
  font-size: var(--fs-body);
  font-weight: 400;
  color: var(--ink);
  letter-spacing: 0.005em;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
.reveal .slides { text-align: left; }
.reveal .slides section,
.reveal .slides section > section {
  padding: 0 !important;
  height: 100%;
}

.reveal h1, .reveal h2, .reveal h3, .reveal h4 {
  font-family: var(--font-stack);
  font-weight: 300;
  color: var(--ink);
  text-transform: none;
  text-shadow: none;
  margin: 0;
  line-height: 1.05;
  letter-spacing: -0.02em;
}
.reveal h1 { font-size: var(--fs-h1); font-weight: 200; }
.reveal h2 { font-size: var(--fs-h2); font-weight: 300; }
.reveal h3 { font-size: var(--fs-h3); font-weight: 500; letter-spacing: 0.02em; }
.reveal p  { line-height: 1.5; margin: 0; }
.reveal a  { color: var(--gold); text-decoration: none; }

/* Eyebrow / kicker label */
.kicker {
  font-size: var(--fs-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 500;
  margin-bottom: 24px;
}
.kicker .dash { display: inline-block; width: 32px; height: 1px; background: var(--gold); vertical-align: middle; margin-right: 14px; transform: translateY(-3px); }

/* Slide number & progress styling */
.reveal .progress {
  height: 2px;
  color: var(--gold);
  background: rgba(255,255,255,0.04);
}
.reveal .slide-number {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  color: var(--ink-dim);
  background: transparent;
  right: 32px;
  bottom: 24px;
}
.reveal .controls { color: var(--ink-dim); }

/* ============================================================================
   SLIDE LAYOUT PRIMITIVES
   ============================================================================ */
.slide-frame {
  position: absolute; inset: 0;
  padding: 72px 96px 80px 96px;
  display: flex; flex-direction: column;
  box-sizing: border-box;
}
.slide-frame.center { justify-content: center; }
.slide-frame > .header-rule {
  position: absolute; left: 96px; right: 96px; top: 56px;
  height: 1px; background: var(--rule);
}
.slide-frame > .footer-meta {
  position: absolute; left: 96px; bottom: 28px;
  font-family: var(--font-mono);
  font-size: 11px; letter-spacing: 0.15em;
  color: var(--ink-dim); text-transform: uppercase;
}
.slide-frame > .footer-meta .sep { color: var(--rule-strong); margin: 0 12px; }

.title-block { max-width: 1100px; }
.title-block .lead { font-size: var(--fs-h2); font-weight: 200; color: var(--ink); line-height: 1.15; }
.title-block .lead em { color: var(--gold); font-style: normal; font-weight: 300; }
.title-block .sub { font-size: var(--fs-body); color: var(--ink-muted); margin-top: 24px; max-width: 760px; line-height: 1.55; }

/* ============================================================================
   SLIDE 1 — TITLE
   ============================================================================ */
.s-title {
  position: absolute; inset: 0;
  display: grid;
  grid-template-rows: auto 1fr auto;
  padding: 56px 96px;
  box-sizing: border-box;
}
.s-title .brand-mark {
  font-family: var(--font-mono); font-size: 11px;
  letter-spacing: 0.25em; text-transform: uppercase;
  color: var(--ink-dim);
  align-self: start;
  position: relative; z-index: 1;
}
.s-title .brand-mark .accent { color: var(--gold); }
.s-title .center-block {
  align-self: center;
  position: relative; z-index: 1;
}
.s-title .display {
  font-size: var(--fs-display);
  font-weight: 200;
  letter-spacing: -0.035em;
  line-height: 0.95;
  color: var(--ink);
}
.s-title .display .gold { color: var(--gold); font-style: italic; font-weight: 300; }
.s-title .subtitle {
  margin-top: 36px;
  font-size: 26px;
  font-weight: 300;
  color: var(--ink-muted);
  letter-spacing: 0.01em;
  max-width: 720px;
  line-height: 1.4;
}
.s-title .meta-row {
  align-self: end;
  display: flex; justify-content: space-between; align-items: flex-end;
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em;
  color: var(--ink-dim); text-transform: uppercase;
  position: relative; z-index: 1;
}
.s-title .meta-row .right { text-align: right; }
.s-title canvas#particles { position: absolute; inset: 0; z-index: 0; }

/* ============================================================================
   SLIDE 2 — ONE SENTENCE (quote build)
   ============================================================================ */
.s-quote .quote-text {
  font-size: clamp(36px, 4.4vw, 64px);
  font-weight: 200;
  line-height: 1.18;
  letter-spacing: -0.02em;
  max-width: 1400px;
  color: var(--ink);
  text-align: left;
}
