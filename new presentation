// SLIDE 3: pillars
const PILLARS = [
  { num: '01', title: 'NAV Production',     blurb: 'Daily, weekly, monthly. Across UCITS, AIFs, and bespoke structures.', detail: '99.97% on-time delivery · 24/5 production' },
  { num: '02', title: 'Reconciliation',     blurb: 'Cash, position, and trade reconciliation across custodians and prime brokers.',           detail: 'Multi-source · automated breaks · STP-first' },
  { num: '03', title: 'Corporate Actions',  blurb: 'Voluntary and mandatory event capture, election, and processing.',                         detail: 'Global coverage · same-day notification' },
  { num: '04', title: 'Financial Reporting',blurb: 'Annual and semi-annual reports, ESMA-compliant, fully audit-ready.',                       detail: 'IFRS · FRS 102 · US GAAP' },
