  { prefix: 'Funds serviced',              value: 2400, decimals: 0, unit: '+',  label: 'UCITS, AIFs, separately managed accounts' },
  { prefix: 'Jurisdictions',               value: 22,   decimals: 0, unit: '',   label: 'Regulatory regimes covered' },
  { prefix: 'NAVs per day',                value: 1850, decimals: 0, unit: '',   label: 'At peak production volume' }
];

// SLIDE 7: regulatory milestones (year-month decimal positions)
const REG_MILESTONES = [
