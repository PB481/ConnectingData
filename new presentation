  { id: 'trades',        col: 0, label: 'Trade events',         sub: 'OMS · counterparty' },
  { id: 'custody',       col: 0, label: 'Custody confirms',     sub: 'SWIFT MT54x · ISO 20022' },
  { id: 'prices',        col: 0, label: 'Market prices',        sub: 'Vendor + manual' },
