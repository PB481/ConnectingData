  if (!svg.node()) return;
  const node = svg.node();
  const bbox = node.getBoundingClientRect();
  const W = bbox.width, H = bbox.height;
  if (!W || !H) return;
  svg.selectAll('*').remove();
  svg.attr('viewBox', `0 0 ${W} ${H}`);

  const m = { top: 32, right: 32, bottom: 48, left: 48 };
  const innerW = W - m.left - m.right, innerH = H - m.top - m.bottom;
  const x = d3.scaleLinear().domain([0, 10]).range([m.left, m.left + innerW]);
  const y = d3.scaleLinear().domain([0, 10]).range([m.top + innerH, m.top]);

  // background
  svg.append('rect').attr('class', 'quad-bg')
    .attr('x', m.left).attr('y', m.top)
    .attr('width', innerW).attr('height', innerH);

  // mid-rules
  svg.append('line').attr('class', 'quad-rule')
    .attr('x1', x(5)).attr('x2', x(5))
    .attr('y1', m.top).attr('y2', m.top + innerH);
  svg.append('line').attr('class', 'quad-rule')
    .attr('x1', m.left).attr('x2', m.left + innerW)
    .attr('y1', y(5)).attr('y2', y(5));

  // axes
  svg.append('line').attr('class', 'quad-axis')
    .attr('x1', m.left).attr('x2', m.left + innerW)
    .attr('y1', m.top + innerH).attr('y2', m.top + innerH);
  svg.append('line').attr('class', 'quad-axis')
    .attr('x1', m.left).attr('x2', m.left)
    .attr('y1', m.top).attr('y2', m.top + innerH);

  // axis labels
  svg.append('text').attr('class', 'quad-axis-label')
    .attr('x', m.left + innerW / 2).attr('y', m.top + innerH + 32)
    .attr('text-anchor', 'middle').text('Product breadth →');
  svg.append('text').attr('class', 'quad-axis-label')
    .attr('transform', `translate(${m.left - 18},${m.top + innerH / 2}) rotate(-90)`)
    .attr('text-anchor', 'middle').text('Platform integration →');

  // corner labels
  const corners = [
    { x: x(0.4),  y: y(9.6), t: 'NICHE PLAYERS' },
    { x: x(9.6),  y: y(9.6), t: 'INTEGRATED LEADERS', anchor: 'end' },
    { x: x(0.4),  y: y(0.5), t: 'POINT SOLUTIONS' },
    { x: x(9.6),  y: y(0.5), t: 'BROAD-LINE',         anchor: 'end' }
  ];
  corners.forEach(c => {
    svg.append('text').attr('class', 'quad-corner-label')
      .attr('x', c.x).attr('y', c.y)
      .attr('text-anchor', c.anchor || 'start').text(c.t);
  });

  // competitors — animate in
  const compG = svg.selectAll('g.competitor')
    .data(COMPETITORS).enter()
    .append('g')
    .attr('class', d => 'competitor' + (d.us ? ' us' : ''))
    .attr('transform', d => `translate(${x(5)},${y(5)})`)
    .style('opacity', 0);

  compG.append('circle').attr('r', d => d.r);
  compG.append('text')
    .attr('y', d => d.r + 16)
    .attr('text-anchor', 'middle')
    .text(d => d.name);

  compG.transition()
    .delay((d, i) => 200 + i * 100)
    .duration(900)
    .ease(d3.easeCubicOut)
    .attr('transform', d => `translate(${x(d.x)},${y(d.y)})`)
    .style('opacity', 1);
}

/* ============================================================================
   SLIDE 9 — OPERATING MODEL
   ============================================================================ */
let opPulseHandle = null;
function drawOpmodel() {
  const svg = d3.select('#opmodel-svg');
  if (!svg.node()) return;
  const node = svg.node();
  const bbox = node.getBoundingClientRect();
  const W = bbox.width, H = bbox.height;
  if (!W || !H) return;
  svg.selectAll('*').remove();
  svg.attr('viewBox', `0 0 ${W} ${H}`);

  // optional very faint grid backdrop
  const gridG = svg.append('g').attr('opacity', 0.04);
  for (let i = 0; i < 20; i++) {
    gridG.append('line').attr('stroke', '#fff').attr('stroke-width', 0.5)
      .attr('x1', (i * W) / 20).attr('x2', (i * W) / 20).attr('y1', 0).attr('y2', H);
  }
  for (let i = 0; i < 12; i++) {
    gridG.append('line').attr('stroke', '#fff').attr('stroke-width', 0.5)
      .attr('x1', 0).attr('x2', W).attr('y1', (i * H) / 12).attr('y2', (i * H) / 12);
  }

  // resolve hub positions
  const hubsByName = {};
  HUBS.forEach(h => { hubsByName[h.name] = { ...h, px: h.x * W, py: h.y * H }; });

  // links
  const linkG = svg.append('g');
  const linkRefs = [];
  HUB_LINKS.forEach(([a, b]) => {
    const A = hubsByName[a], B = hubsByName[b];
    if (!A || !B) return;
    const mx = (A.px + B.px) / 2;
    const my = (A.py + B.py) / 2 - 30;
    const path = linkG.append('path')
      .attr('class', 'link-line')
      .attr('d', `M${A.px},${A.py} Q${mx},${my} ${B.px},${B.py}`);
    linkRefs.push(path.node());
  });

  // hubs
  const hubG = svg.append('g');
  Object.values(hubsByName).forEach((h, i) => {
    const g = hubG.append('g')
      .attr('transform', `translate(${h.px},${h.py})`)
      .style('opacity', 0);
    g.append('circle')
      .attr('class', 'hub-circle' + (h.primary ? ' primary' : ''))
      .attr('r', h.primary ? 12 : 8);
    g.append('text').attr('class', 'hub-tier').attr('y', -28).text(h.tier);
    g.append('text').attr('class', 'hub-label').attr('y', 30).text(h.name);
    g.append('text').attr('class', 'hub-sub').attr('y', 46).text(h.sub);

    g.transition().delay(150 + i * 80).duration(500).style('opacity', 1);
  });

  // pulses
  if (opPulseHandle) cancelAnimationFrame(opPulseHandle);
  const pulseLayer = svg.append('g');
  const pulses = [];
  function spawnPulse() {
    if (!linkRefs.length) return;
    pulses.push({ path: linkRefs[Math.floor(Math.random() * linkRefs.length)], t: 0, speed: 0.0015 + Math.random() * 0.001 });
  }
  let last = performance.now(), spawnT = 0;
  function tick(now) {
    const dt = Math.min(50, now - last); last = now;
    spawnT += dt;
    if (spawnT > 250) { spawnPulse(); spawnT = 0; }
    pulseLayer.selectAll('circle').remove();
    for (let i = pulses.length - 1; i >= 0; i--) {
      const p = pulses[i];
      p.t += p.speed * dt;
      if (p.t >= 1) { pulses.splice(i, 1); continue; }
      const len = p.path.getTotalLength();
      const pt = p.path.getPointAtLength(p.t * len);
      pulseLayer.append('circle')
        .attr('class', 'pulse')
        .attr('cx', pt.x).attr('cy', pt.y).attr('r', 2)
        .style('fill-opacity', 0.9 * (1 - Math.abs(p.t - 0.5) * 2));
    }
    opPulseHandle = requestAnimationFrame(tick);
  }
  opPulseHandle = requestAnimationFrame(tick);
}
function stopOpPulse() {
  if (opPulseHandle) { cancelAnimationFrame(opPulseHandle); opPulseHandle = null; }
}

/* ============================================================================
   SLIDE 10 — TECH STACK
   ============================================================================ */
function buildStack() {
  const wrap = document.getElementById('stack-wrap');
  if (!wrap) return;
  wrap.innerHTML = STACK_LAYERS.map(l => `
    <div class="stack-layer">
      <div class="layer-meta">
        <div class="num">LAYER ${l.num}</div>
        <div class="name">${l.name}</div>
      </div>
      <div class="layer-items">
        ${l.items.map(it => `<div class="chip${(l.gold || []).includes(it) ? ' gold' : ''}">${it}</div>`).join('')}
      </div>
    </div>
  `).join('');
}
function playStack() {
  const layers = $$('#stack-wrap .stack-layer');
  if (!layers.length) return;
  // bottom-up reveal: reverse order
  gsap.set(layers, { opacity: 0, y: 8 });
  gsap.to([...layers].reverse(), { opacity: 1, y: 0, duration: 0.45, stagger: 0.09, ease: 'power3.out' });
}

/* ============================================================================
   SLIDE 11 — WHY JPM
   ============================================================================ */
function buildWhy() {
  const grid = document.getElementById('why-grid');
  if (!grid) return;
  grid.innerHTML = WHY.map(w => `
    <div class="why-card">
      <div class="why-num">${w.num}</div>
      <div class="why-stat">${w.prefix ? `<span class="prefix">${w.prefix}</span>` : ''}<span class="num" data-target="${w.stat}" data-decimals="${w.decimals}">0</span><span class="unit">${w.unit}</span></div>
      <h2>${w.headline}</h2>
      <p>${w.body}</p>
    </div>
  `).join('');
}
function playWhy() {
  $$('#why-grid .num').forEach(el => {
    const target = parseFloat(el.dataset.target);
    const decimals = parseInt(el.dataset.decimals, 10);
    const obj = { v: 0 };
    gsap.to(obj, {
      v: target, duration: 1.4, ease: 'power3.out',
      onUpdate: () => { el.textContent = obj.v.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals }); }
    });
  });
  gsap.from('.why-card', { opacity: 0, y: 14, duration: 0.5, stagger: 0.12, ease: 'power3.out' });
}

/* ============================================================================
   STATIC INIT — build static markup that doesn't need the slide to be visible
   ============================================================================ */
function initStatic() {
  buildPillars();
  buildScale();
  buildStack();
  buildWhy();
  prepareQuote();
}

/* ============================================================================
   SLIDE LIFECYCLE — run animations on slide enter
   ============================================================================ */
function onSlideShown(event) {
  const slide = event.currentSlide;
  const id = slide ? slide.dataset.slide : null;

  // stop continuous animations from other slides
  if (id !== 'flow') stopFlowParticles();
  if (id !== 'opmodel') stopOpPulse();

  // defer one frame so Reveal has applied its transform/scale to the slide,
  // letting getBoundingClientRect return final post-transform dimensions
  requestAnimationFrame(() => {
    switch (id) {
      case 'title':       /* particle bg already running */ break;
      case 'quote':       playQuote(); break;
      case 'pillars':     playPillars(); break;
      case 'gantt':       drawGantt(); break;
      case 'flow':        drawFlow(); break;
      case 'scale':       playScale(); break;
      case 'regulatory':  drawReg(); playReg(); break;
      case 'quad':        drawQuad(); break;
      case 'opmodel':     drawOpmodel(); break;
      case 'stack':       playStack(); break;
      case 'why':         playWhy(); break;
      case 'closing':     break;
    }
  });
}

/* ============================================================================
   BOOT
   ============================================================================ */
document.addEventListener('DOMContentLoaded', () => {
  initStatic();
  initParticles();

  // Reveal init
  Reveal.initialize({
    width: 1600,
    height: 900,
    margin: 0.04,
    minScale: 0.4,
    maxScale: 1.6,
    hash: true,
    progress: true,
    slideNumber: 'c/t',
    controls: true,
    controlsLayout: 'edges',
    transition: 'fade',
    transitionSpeed: 'default',
    backgroundTransition: 'fade',
    pdfSeparateFragments: false,
    keyboard: true,
    overview: true,
    touch: true
  }).then(() => {
    Reveal.on('slidechanged', onSlideShown);
    Reveal.on('ready', onSlideShown);
    // Bind gantt toggle once Reveal has rendered the DOM
    const btn = document.getElementById('gantt-now-toggle');
    if (btn) btn.addEventListener('click', toggleGanttNow);

    // Force any visible chart that depends on layout to redraw on resize
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        const cur = Reveal.getCurrentSlide();
        if (cur) onSlideShown({ currentSlide: cur });
      }, 200);
    });
  });
});
</script>

