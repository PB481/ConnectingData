with b1:
    st.markdown("**Builder A**")
    st.code(f"""from tool_library import liquidity_cost_model
```

def compute_swing_factor(positions, net_flow_pct, stress_mult):
"""Generated from semantic.SwingFactor.derivation
Constraint: 0 <= factor_bps <= 200
"""
if abs(net_flow_pct) <= 0.005:
return 0.0
factor_bps = 0.0
for p in positions[:13]:
cost_bps = liquidity_cost_model(
horizon_days=p.liquidation_horizon_days,
stress=stress_mult)
factor_bps += p.weight * cost_bps
return factor_bps

# Output: {swing.factor_bps:.4f} bps”””, language=“python”)

```
with b2:
    st.markdown("**Builder B**")
    st.code(f"""from tools import lcm
```

def swing(positions, flow_ratio, stress):
"""Per SwingFactor entity: basis-points adjustment"""
if abs(flow_ratio) <= 0.005:
return 0.0
contributions = [
p.weight * lcm(p.liquidation_horizon_days, stress)
for p in positions[:13]
]
return sum(contributions)

# Output: {swing.factor_bps:.4f} bps”””, language=“python”)

