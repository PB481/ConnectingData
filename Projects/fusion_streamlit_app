if st.button("Generate reconciliation grid"):
    rows = []
    for f_pct in [-0.04, -0.02, -0.01, 0.01, 0.02, 0.04]:
        for r_name in ["normal", "stress", "crisis"]:
            f = generate_fund(flow_pct=f_pct, mix=mix, regime=r_name,
                              aum_eur=aum_m * 1_000_000, fund_id=fund_id)
            s = calculate_swing_factor(f)
            cs = verify(f, s)
            o = certify(f, s, cs)
            rows.append({
                "Flow %": f_pct * 100,
                "Regime": r_name,
                "Net flow (€M)": f.net_flow_eur / 1e6,
                "Swing (bps)": s.factor_bps,
                "Swung NAV (€M)": o.swung_nav_eur / 1e6,
                "Z3": "✓" if cs[0].passed else "✗",
                "Anomaly": "✓" if cs[5].passed else "REVIEW",
                "Certified": "✓" if o.certified else "REVIEW",
                "Proof": o.proof_hash,
            })
    df_grid = pd.DataFrame(rows)
    st.session_state.recon = df_grid

if "recon" in st.session_state:
    st.dataframe(
        st.session_state.recon.style.format({
            "Flow %": "{:+.2f}%",
            "Net flow (€M)": "€{:+,.2f}M",
            "Swing (bps)": "{:.2f}",
            "Swung NAV (€M)": "€{:,.2f}M",
        }),
        use_container_width=True, hide_index=True,
    )

    # CSV download
    csv = st.session_state.recon.to_csv(index=False).encode("utf-8")
    st.download_button(
        "Download reconciliation pack (CSV)",
        data=csv,
        file_name=f"recon_{fund_id}_{date.today().isoformat()}.csv",
        mime="text/csv",
    )
