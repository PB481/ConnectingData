  if (persona === "adversarial") {
    fa = fa.replace(/fairValueEUR/g, "fairValue_USD");
    perturbations.push("FA unit drift: EUR fields renamed USD (caught by semantic layer unit check)");
  }
  if (persona === "legacy") {
    mo = mo.replace(/\|/g, "\t").replace("pipe-delimited", "tab-delimited (legacy migration artefact)");
    perturbations.push("MO format collision: pipe → tab delimiter (auto-detected)");
  }

  return { custody, fa, mo, perturbations };
}

