// ============================================================
// SWING PRICING CALCULATION
// ============================================================
function calcSwingFactor(fund) {
  // Simplified MSCI-style liquidity-cost model
  const flowAbs = Math.abs(fund.netFlow);
  const swingThreshold = 0.005; // 50bps of AUM
  const breached = (flowAbs / fund.aum) > swingThreshold;

  if (!breached) return { factor_bps: 0, breached: false, contribs: [] };

  // Per-position transaction cost as a function of liquidation horizon
  const contribs = fund.positions.slice(0, 13).map(p => {
    // Cost increases with liquidity horizon and stress
    const costBps = 5 + p.liquidityDays * 0.6 * fund.stressMult;
    const contribution = p.weight * costBps;
    return { isin: p.isin, weight: p.weight, costBps, contribution };
  });

  const factor = contribs.reduce((a, c) => a + c.contribution, 0);
  return { factor_bps: factor, breached: true, contribs };
}

