        <div class="stat">
          <div class="stat-label">Net flow</div>
          <div class="stat-val amber" id="kpi-flow">€0.0M</div>
          <div class="stat-sub" id="kpi-flow-pct">0.00% AUM</div>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
        <div>
          <div class="panel-title" style="margin-bottom: 10px;">Top positions (synthetic)</div>
