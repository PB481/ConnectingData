    for p in positions[:13]:  # material positions only
        cost_bps = liquidity_cost_model(
            horizon_days=p.liquidationHorizon,
            stress=stress_mult
        )  # Tool Library v2.4.1
        factor_bps += p.weight * cost_bps
    
    return factor_bps

# Tools called: liquidity_cost_model · position_weight
# Output: ${swing.factor_bps.toFixed(4)} bps`;

  builderBCode = `# BUILDER B · independently generated
from tools import lcm, weights

def swing(positions, flow_ratio, stress):
    """Per SwingFactor entity: basis-points adjustment
    Z3 constraint: factor_bps ∈ [0, maxFactor]
    """
    if abs(flow_ratio) <= 0.005:
        return 0.0
    
    contributions = [
        p.weight * lcm(p.liquidationHorizon, stress)
        for p in positions[:13]
    ]
    return sum(contributions)

# Tools called: lcm · weights
# Output: ${swing.factor_bps.toFixed(4)} bps`;

  $("builder-code").textContent = builderACode;
  $("builder-a").textContent = swing.factor_bps.toFixed(2);
  $("builder-b").textContent = swing.factor_bps.toFixed(2);
  $("builder-consensus").textContent = "PASS";
  $("builder-tools").textContent = "2 + 2";
}

function renderVerifications(fund, swing, checks) {
  $("verif-grid").innerHTML = checks.map(c =>
    `<div class="verif-card ${c.pass ? 'pass' : ''}">
      <div class="verif-head">
        <span class="verif-name">${c.name}</span>
        <span class="verif-badge ${c.pass ? 'pass' : ''}">${c.pass ? "PASS" : "FAIL"}</span>
      </div>
      <div class="verif-detail">${c.detail}</div>
    </div>`
  ).join("");

  const allPass = checks.every(c => c.pass);
  const navStrike = fund.aum * (1 + Math.sign(fund.netFlow) * swing.factor_bps / 10000);
  const cert = `# CERTIFIED OUTPUT · CRYPTOGRAPHICALLY SIGNED
{
  "fund": "EMERALD-CAP-I",
  "navDate": "${new Date().toISOString().slice(0,10)}",
  "priorNav_EUR": ${fund.aum.toFixed(2)},
  "netFlow_EUR": ${fund.netFlow.toFixed(2)},
  "netFlowPct": ${(fund.flowPct).toFixed(6)},
  "swingThresholdBreached": ${swing.breached},
  "swingFactor_bps": ${swing.factor_bps.toFixed(4)},
  "swungNav_EUR": ${navStrike.toFixed(2)},
  "verification": {
    "z3": "PASS",
    "dual_builder": "PASS",
    "inverse": "PASS",
    "property_1000": "PASS",
    "tool_lib_regression": "PASS",
    "anomaly_agent": "${swing.factor_bps < 100 ? 'PASS' : 'REVIEW'}"
  },
  "tool_library_versions": {
    "liquidity_cost_model": "v2.4.1",
    "position_weight": "v1.8.0"
  },
  "proof_hash": "0x${(Math.random()*1e16).toString(16).slice(0,12)}",
  "certified": ${allPass}
}`;
  $("cert-output").textContent = cert;
}

function setStatus(stage, state) {
  const el = $("status-" + stage);
  el.classList.remove("done");
  if (state === "done") el.classList.add("done");
  el.querySelector("span:last-child").textContent = state.toUpperCase();
}

// Init
const initFund = generateFund({ flow: 0, mix: "balanced", regime: "normal" });
renderFund(initFund);
renderSemantic();
log("Demo initialised. Configure inputs and click RUN PIPELINE.", "info");

// RUN
$("runBtn").addEventListener("click", async () => {
  const btn = $("runBtn");
  btn.disabled = true;
  consoleEl.innerHTML = "";
  const t0 = performance.now();

  // Reset statuses
  for (let i = 0; i < 5; i++) setStatus(i, "waiting");

  const controls = {
    flow: parseInt($("flow").value),
    mix: $("mix").value,
    regime: $("regime").value
  };
  const persona = $("persona").value;

  log(`Pipeline start · flow=${(controls.flow/100).toFixed(2)}% · mix=${controls.mix} · regime=${controls.regime} · persona=${persona}`, "info");

  // Stage 0
  await sleep(200);
  log("Stage 01 · Generating synthetic QIAIF (Emerald Capital Partners I)...", "");
  const fund = generateFund(controls);
  renderFund(fund);
  await sleep(400);
  log(`Stage 01 · ${fund.positions.length} positions · ${fund.flows.length} flow tickets · €${(fund.netFlow/1e6).toFixed(2)}M net`, "success");
  setStatus(0, "done");
  $("pill-stages").textContent = "1 / 5 stages";

  // Stage 1
  await sleep(300);
  log("Stage 02 · Fusion-style Reader · 3 sources (Custody, FA, MO)", "");
  renderReader(fund, persona);
  await sleep(500);
  if (persona !== "senior") {
    log(`Stage 02 · Persona perturbation detected · resolved by semantic-layer unit/identifier validation`, "warn");
  }
  log(`Stage 02 · 147 positions normalised · 100% lineage · 0 unresolved fields`, "success");
  setStatus(1, "done");
  $("pill-stages").textContent = "2 / 5 stages";

  // Stage 2
  await sleep(300);
  log("Stage 03 · Semantic layer · 4 entities loaded (Position, SubscriptionFlow, NAVStrike, SwingFactor)", "");
  await sleep(400);
  log("Stage 03 · YAML constitution validated · 12 constraints registered with Z3", "success");
  setStatus(2, "done");
  $("pill-stages").textContent = "3 / 5 stages";

  // Stage 3
  await sleep(400);
  log("Stage 04 · Builder A generating swing-factor calculation code...", "");
  await sleep(700);
  log("Stage 04 · Builder B independently generating equivalent code...", "");
  await sleep(700);
  const swing = calcSwingFactor(fund);
  renderBuilders(fund, swing);
  log(`Stage 04 · Both Builders converged · ${swing.factor_bps.toFixed(4)} bps · |Δ|=0.0000 · 4 tool calls`, "success");
  setStatus(3, "done");
  $("pill-stages").textContent = "4 / 5 stages";
  $("pill-tools").textContent = "4 tools called";

  // Stage 4
  await sleep(400);
  log("Stage 05 · Verification cascade · 6 layers...", "");
  const checks = runVerifications(fund, swing);
  for (let i = 0; i < checks.length; i++) {
    await sleep(180);
    log(`Stage 05 · ${checks[i].name} · ${checks[i].pass ? "PASS" : "REVIEW"}`, checks[i].pass ? "success" : "warn");
  }
  renderVerifications(fund, swing, checks);
  setStatus(4, "done");
  $("pill-stages").textContent = "5 / 5 stages";
  $("pill-proofs").textContent = "6 proofs";
  $("pill-anom").textContent = checks.filter(c => !c.pass).length + " anomalies";

  const elapsed = ((performance.now() - t0) / 1000).toFixed(1);
  $("elapsed").textContent = elapsed + "s";
  log(`Pipeline complete in ${elapsed}s · output certified · ready for distribution via Fusion Drive / API / notebook`, "info");
  btn.disabled = false;
  
  // Auto-jump to verification view
  document.querySelector('.step[data-stage="4"]').click();
});

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
</script>

