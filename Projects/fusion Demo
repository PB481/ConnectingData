<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>Verified Swing Pricing — Fusion Integration Demo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a1628;
    --bg-2: #0f1d35;
    --panel: #142844;
    --panel-2: #1a3052;
    --line: #1f3a5f;
    --line-2: #2a4a73;
    --text: #e8eef7;
    --text-dim: #8da4c0;
    --text-faint: #5a7494;
    --cyan: #00d4ff;
    --cyan-dim: #0088aa;
    --green: #4ade80;
    --amber: #fbbf24;
    --red: #f87171;
    --magenta: #c084fc;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    line-height: 1.5;
    min-height: 100vh;
  }
  body {
    background:
      radial-gradient(ellipse at top left, rgba(0, 212, 255, 0.06), transparent 50%),
      radial-gradient(ellipse at bottom right, rgba(192, 132, 252, 0.04), transparent 50%),
      var(--bg);
  }
  .mono { font-family: 'JetBrains Mono', monospace; }

/* ===== Header ===== */
header {
border-bottom: 1px solid var(–line);
background: rgba(10, 22, 40, 0.85);
backdrop-filter: blur(8px);
position: sticky;
top: 0;
z-index: 10;
}
.header-inner {
max-width: 1400px;
margin: 0 auto;
padding: 18px 32px;
display: flex;
align-items: center;
justify-content: space-between;
}
.brand {
display: flex;
align-items: center;
gap: 14px;
}
.logo-mark {
width: 36px; height: 36px;
border: 1.5px solid var(–cyan);
position: relative;
display: grid;
place-items: center;
}
.logo-mark::before {
content: “”; position: absolute; inset: 4px;
border: 1px solid var(–cyan-dim);
}
.logo-mark::after {
content: “∑”; font-family: ‘JetBrains Mono’, monospace;
font-weight: 700; color: var(–cyan); font-size: 14px;
z-index: 1;
}
.brand-text { display: flex; flex-direction: column; }
.brand-title { font-weight: 700; font-size: 15px; letter-spacing: 0.02em; }
.brand-sub { font-size: 11px; color: var(–text-dim); font-family: ‘JetBrains Mono’, monospace; letter-spacing: 0.05em; }
.header-meta {
display: flex; gap: 24px; font-family: ‘JetBrains Mono’, monospace; font-size: 11px;
color: var(–text-dim); letter-spacing: 0.04em;
}
.header-meta span b { color: var(–cyan); font-weight: 500; }

/* ===== Layout ===== */
main {
max-width: 1400px;
margin: 0 auto;
padding: 32px;
}

.hero {
margin-bottom: 36px;
}
.hero-eyebrow {
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
color: var(–cyan);
letter-spacing: 0.18em;
margin-bottom: 14px;
text-transform: uppercase;
}
.hero h1 {
font-size: 38px;
font-weight: 700;
letter-spacing: -0.02em;
line-height: 1.1;
margin-bottom: 14px;
max-width: 900px;
}
.hero h1 .accent { color: var(–cyan); }
.hero p {
color: var(–text-dim);
font-size: 15px;
max-width: 780px;
line-height: 1.6;
}

/* ===== Pipeline ribbon ===== */
.pipeline {
display: grid;
grid-template-columns: repeat(5, 1fr);
gap: 0;
margin-bottom: 32px;
border: 1px solid var(–line);
background: var(–panel);
}
.step {
padding: 18px 20px;
border-right: 1px solid var(–line);
cursor: pointer;
transition: background 0.2s, border-color 0.2s;
position: relative;
}
.step:last-child { border-right: none; }
.step:hover { background: var(–panel-2); }
.step.active { background: var(–panel-2); }
.step.active::after {
content: “”; position: absolute; left: 0; right: 0; bottom: -1px; height: 2px;
background: var(–cyan);
}
.step-num {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10px; color: var(–text-faint); letter-spacing: 0.1em;
}
.step-name {
font-weight: 700; font-size: 14px; margin-top: 4px;
}
.step-desc { font-size: 11px; color: var(–text-dim); margin-top: 4px; }
.step-status {
margin-top: 8px;
display: inline-flex; align-items: center; gap: 6px;
font-family: ‘JetBrains Mono’, monospace; font-size: 10px;
letter-spacing: 0.05em;
}
.step-status .dot {
width: 6px; height: 6px; border-radius: 50%; background: var(–text-faint);
}
.step-status.done .dot { background: var(–green); box-shadow: 0 0 8px var(–green); }
.step-status.done { color: var(–green); }

/* ===== Workspace ===== */
.workspace {
display: grid;
grid-template-columns: 320px 1fr;
gap: 24px;
margin-bottom: 32px;
}
.panel {
border: 1px solid var(–line);
background: var(–panel);
}
.panel-header {
padding: 14px 18px;
border-bottom: 1px solid var(–line);
display: flex;
align-items: center;
justify-content: space-between;
}
.panel-title {
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
color: var(–text-dim);
letter-spacing: 0.12em;
text-transform: uppercase;
}
.panel-body { padding: 18px; }

/* Controls */
.control {
margin-bottom: 18px;
}
.control-label {
font-size: 12px;
color: var(–text-dim);
margin-bottom: 6px;
display: flex;
justify-content: space-between;
}
.control-label .val { color: var(–cyan); font-family: ‘JetBrains Mono’, monospace; }
input[type=“range”] {
-webkit-appearance: none;
width: 100%;
height: 4px;
background: var(–line-2);
outline: none;
border-radius: 2px;
}
input[type=“range”]::-webkit-slider-thumb {
-webkit-appearance: none;
width: 14px; height: 14px;
background: var(–cyan);
border-radius: 50%;
cursor: pointer;
box-shadow: 0 0 0 4px rgba(0, 212, 255, 0.15);
}
input[type=“range”]::-moz-range-thumb {
width: 14px; height: 14px;
background: var(–cyan);
border-radius: 50%;
cursor: pointer;
border: none;
}
select {
width: 100%;
background: var(–bg-2);
color: var(–text);
border: 1px solid var(–line-2);
padding: 8px 10px;
font-family: ‘DM Sans’, sans-serif;
font-size: 13px;
}
button.run {
width: 100%;
background: var(–cyan);
color: var(–bg);
border: none;
padding: 12px;
font-family: ‘JetBrains Mono’, monospace;
font-weight: 700;
font-size: 12px;
letter-spacing: 0.12em;
cursor: pointer;
transition: all 0.15s;
}
button.run:hover { background: #fff; transform: translateY(-1px); }
button.run:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

/* Stage detail */
.stage-detail { min-height: 600px; }
.stage-content { padding: 24px; }
.stage-content h2 {
font-size: 22px; font-weight: 700; margin-bottom: 6px;
}
.stage-content .stage-eyebrow {
font-family: ‘JetBrains Mono’, monospace; font-size: 11px;
color: var(–cyan); letter-spacing: 0.15em; margin-bottom: 8px;
text-transform: uppercase;
}
.stage-content > p {
color: var(–text-dim); margin-bottom: 24px; max-width: 760px;
}

/* Tables */
.data-table {
width: 100%;
border-collapse: collapse;
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
}
.data-table th {
text-align: left;
padding: 10px 14px;
border-bottom: 1px solid var(–line-2);
color: var(–text-dim);
font-weight: 500;
font-size: 10px;
letter-spacing: 0.1em;
text-transform: uppercase;
}
.data-table td {
padding: 9px 14px;
border-bottom: 1px solid var(–line);
color: var(–text);
}
.data-table tr:hover td { background: rgba(0, 212, 255, 0.03); }
.data-table .num { text-align: right; }
.data-table .neg { color: var(–red); }
.data-table .pos { color: var(–green); }

/* Code block */
.code {
background: var(–bg-2);
border: 1px solid var(–line);
padding: 16px 20px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
line-height: 1.7;
overflow-x: auto;
margin-bottom: 16px;
}
.code .kw { color: var(–magenta); }
.code .fn { color: var(–cyan); }
.code .str { color: var(–green); }
.code .num-tok { color: var(–amber); }
.code .com { color: var(–text-faint); font-style: italic; }

/* Stat grid */
.stat-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 1px;
background: var(–line);
border: 1px solid var(–line);
margin-bottom: 24px;
}
.stat {
background: var(–panel);
padding: 16px 18px;
}
.stat-label {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10px;
color: var(–text-dim);
letter-spacing: 0.1em;
text-transform: uppercase;
margin-bottom: 6px;
}
.stat-val {
font-family: ‘JetBrains Mono’, monospace;
font-size: 22px;
font-weight: 700;
}
.stat-val.cyan { color: var(–cyan); }
.stat-val.green { color: var(–green); }
.stat-val.amber { color: var(–amber); }
.stat-sub {
font-size: 11px;
color: var(–text-faint);
margin-top: 4px;
font-family: ‘JetBrains Mono’, monospace;
}

/* Verification grid */
.verif-grid {
display: grid;
grid-template-columns: repeat(2, 1fr);
gap: 12px;
}
.verif-card {
border: 1px solid var(–line-2);
padding: 14px 16px;
background: var(–bg-2);
}
.verif-card.pass {
border-color: var(–green);
background: linear-gradient(180deg, rgba(74, 222, 128, 0.04), transparent);
}
.verif-head {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 6px;
}
.verif-name {
font-weight: 700;
font-size: 13px;
}
.verif-badge {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10px;
padding: 2px 8px;
border: 1px solid currentColor;
letter-spacing: 0.1em;
}
.verif-badge.pass { color: var(–green); }
.verif-detail {
font-size: 12px;
color: var(–text-dim);
font-family: ‘JetBrains Mono’, monospace;
line-height: 1.6;
}

/* Tabs */
.tabs {
display: flex;
gap: 0;
border-bottom: 1px solid var(–line);
margin-bottom: 20px;
}
.tab {
padding: 10px 18px;
cursor: pointer;
color: var(–text-dim);
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
letter-spacing: 0.08em;
text-transform: uppercase;
border-bottom: 2px solid transparent;
transition: all 0.15s;
}
.tab:hover { color: var(–text); }
.tab.active {
color: var(–cyan);
border-bottom-color: var(–cyan);
}

.hidden { display: none !important; }

/* Persona pills */
.pill-row {
display: flex;
gap: 8px;
flex-wrap: wrap;
margin-bottom: 14px;
}
.pill {
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
padding: 4px 10px;
border: 1px solid var(–line-2);
color: var(–text-dim);
}
.pill.cyan { color: var(–cyan); border-color: var(–cyan-dim); }
.pill.amber { color: var(–amber); border-color: var(–amber); }

/* Console */
.console {
background: #050d1a;
border: 1px solid var(–line);
padding: 16px 20px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
line-height: 1.7;
max-height: 300px;
overflow-y: auto;
}
.console-line { color: var(–text-dim); }
.console-line .ts { color: var(–text-faint); }
.console-line.success { color: var(–green); }
.console-line.warn { color: var(–amber); }
.console-line.info { color: var(–cyan); }

/* Footer */
footer {
max-width: 1400px;
margin: 40px auto;
padding: 24px 32px;
border-top: 1px solid var(–line);
color: var(–text-faint);
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
letter-spacing: 0.05em;
display: flex; justify-content: space-between;
}

/* Reveal */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(8px); }
to { opacity: 1; transform: translateY(0); }
}
.reveal { animation: fadeUp 0.4s ease-out forwards; }
</style>

</head>
