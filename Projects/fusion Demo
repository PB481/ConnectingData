function rand(seed) {
  let s = seed;
  return () => {
    s = (s * 9301 + 49297) % 233280;
    return s / 233280;
  };
}

function generateFund(controls) {
  const r = rand(42 + controls.flow);
  const aum = 500_000_000;
  const flowPct = controls.flow / 10000;
  const netFlow = aum * flowPct;

  const mixMap = {
    balanced: { EQ: 0.60, FI: 0.30, ALT: 0.10 },
    equity:   { EQ: 0.80, FI: 0.15, ALT: 0.05 },
    alts:     { EQ: 0.40, FI: 0.30, ALT: 0.30 },
    credit:   { EQ: 0.20, FI: 0.70, ALT: 0.10 }
  };
  const mix = mixMap[controls.mix];

  // Liquidity stress multiplier
  const stressMult = controls.regime === "normal" ? 1 : (controls.regime === "stress" ? 2 : 4);

  const positions = ISSUERS.map(([isin, name, ac, liq, baseW]) => {
    const adjW = baseW * mix[ac] / (ac === "EQ" ? 0.6 : ac === "FI" ? 0.3 : 0.1);
    const mv = aum * adjW;
    const liqAdj = liq * stressMult;
    return { isin, name, ac, liquidityDays: liqAdj, mv, weight: adjW };
  });

  // Normalise weights to sum to 1
  const totalW = positions.reduce((a, p) => a + p.weight, 0);
  positions.forEach(p => { p.weight = p.weight / totalW; p.mv = aum * p.weight; });

  // Generate a realistic position count by adding more synthetic line items
  const expandedPositions = [...positions];
  for (let i = 0; i < 134; i++) {
    expandedPositions.push({
      isin: "IE00SYN" + String(i).padStart(7, "0"),
      name: "Synth Line " + (i+1),
      ac: ["EQ", "FI", "ALT"][i % 3],
      liquidityDays: (1 + (i % 14)) * stressMult,
      mv: 0,
      weight: 0
    });
  }

  // Flows
  const flows = [];
  if (Math.abs(netFlow) > 100) {
    const numFlows = 4 + Math.floor(r() * 4);
    let remaining = netFlow;
    for (let i = 0; i < numFlows; i++) {
      const investor = INVESTORS[Math.floor(r() * INVESTORS.length)];
      const isLast = i === numFlows - 1;
      const amt = isLast ? remaining : Math.round(remaining * (0.15 + r() * 0.25));
      flows.push({
        investor,
        type: amt >= 0 ? "Subscription" : "Redemption",
        amount: amt
      });
      remaining -= amt;
    }
  }

  return {
    aum,
    netFlow,
    flowPct,
    positions: expandedPositions,
    flows,
    investors: INVESTORS.length + 30,
    regime: controls.regime,
    stressMult,
    mix: controls.mix
  };
}

