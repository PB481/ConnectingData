... (144 more rows)`;

  let fa = `# FUND ACCOUNTING · JSON format · IFRS 9 classified
{
  "asOfDate": "2025-05-04",
  "navPriorEUR": ${fund.aum.toFixed(2)},
  "positions": [
${top.map(p => `    { "id":"${p.isin}", "fairValueEUR":${p.mv.toFixed(2)}, "classification":"${p.ac === 'EQ' ? 'FVTPL' : p.ac === 'FI' ? 'FVOCI' : 'FVTPL'}" }`).join(",\n")}
  ]
}`;

  let mo = `# MIDDLE OFFICE · pipe-delimited · OASYS legacy
SECID|TRADE_DT|SETTLE_DT|UNITS|PX|FX_RATE|CCY
${top.map(p => `${p.isin}|2025-05-02|2025-05-04|${(p.mv/100).toFixed(0)}|100.00|1.0850|EUR`).join("\n")}
... (144 more rows)`;

  // Persona perturbations
  const perturbations = [];
  if (persona === "junior") {
    custody = custody.replace("MarketValue_EUR", "Market Value (EUR)");
    perturbations.push("Custody header drift: 'MarketValue_EUR' → 'Market Value (EUR)'");
