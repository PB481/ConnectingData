// ─── CONSTANTS & HELPERS ─────────────────────────────────────────────────────

const TASK_THRESHOLD = 5.5;
const MONTHS_OVERDUE  = 18;

function monthsSince(dateStr) {
  if (!dateStr) return 0;
  const d = new Date(dateStr);
  const now = new Date();
  return (now.getFullYear() - d.getFullYear()) * 12 + (now.getMonth() - d.getMonth());
}
function formatDateIE()  { return new Date().toLocaleDateString('en-IE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }); }
function shortDateIE()   { return new Date().toLocaleDateString('en-IE'); }
function todayISO()      { return new Date().toISOString().slice(0, 10); }

// localStorage helpers
function loadData(key, fallback) {
  try { const s = localStorage.getItem('cc_' + key); return s ? JSON.parse(s) : JSON.parse(JSON.stringify(fallback)); }
  catch { return JSON.parse(JSON.stringify(fallback)); }
}
function saveData(key, data) {
  try { localStorage.setItem('cc_' + key, JSON.stringify(data)); } catch {}
}

// ─── DATA EXPORT / IMPORT ────────────────────────────────────────────────────
// All data keys the app uses
const DATA_KEYS = ['billing','rfp','pipeline','sales','products','clientmap'];
const DATA_DEFAULTS = {
  billing: INITIAL_BILLING, rfp: INITIAL_RFP_MODULES, pipeline: INITIAL_PIPELINE,
  sales: INITIAL_SALES, products: INITIAL_PRODUCTS, clientmap: INITIAL_CLIENT_MAP,
};

function exportAllData() {
  const bundle = {};
  DATA_KEYS.forEach(k => { bundle[k] = loadData(k, DATA_DEFAULTS[k]); });
  bundle._exported = new Date().toISOString();
  bundle._version  = '2.1';
  const blob = new Blob([JSON.stringify(bundle, null, 2)], { type: 'application/json' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = 'command-center-data_' + todayISO() + '.json';
  a.click();
  URL.revokeObjectURL(url);
}

function importDataFromFile(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const bundle = JSON.parse(e.target.result);
        DATA_KEYS.forEach(k => { if (bundle[k]) saveData(k, bundle[k]); });
        resolve(bundle._exported || 'unknown');
      } catch (err) { reject(err); }
    };
    reader.onerror = reject;
    reader.readAsText(file);
  });
}

function resetAllData() {
  DATA_KEYS.forEach(k => localStorage.removeItem('cc_' + k));
}

// Try to auto-load data.json from same folder on first visit
(function autoLoadDataFile() {
  if (localStorage.getItem('cc_billing')) return; // already has data, skip
  fetch('./data.json').then(r => { if (r.ok) return r.json(); throw 'no file'; })
    .then(bundle => { DATA_KEYS.forEach(k => { if (bundle[k]) saveData(k, bundle[k]); }); })
    .catch(() => {}); // no data.json found, use defaults — that's fine
})();
</script>

