}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘IBM Plex Sans’, system-ui, sans-serif;
min-height: 100vh;
line-height: 1.6;
}

/* ── GRAIN OVERLAY ── */
body::before {
content: ‘’;
position: fixed; top: 0; left: 0; width: 100%; height: 100%;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’ opacity=‘0.03’/%3E%3C/svg%3E”);
pointer-events: none; z-index: 9999;
}

.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* ── HEADER ── */
.header {
padding: 60px 0 48px;
border-bottom: 1px solid var(–border);
}
.header-eyebrow {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 11px;
letter-spacing: 4px;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 12px;
}
.header h1 {
font-size: 36px;
font-weight: 700;
letter-spacing: -1px;
line-height: 1.2;
margin-bottom: 8px;
}
.header h1 span { color: var(–gold); }
.header-sub {
font-size: 16px;
color: var(–text-secondary);
max-width: 740px;
line-height: 1.7;
}

/* ── KEY INSIGHT BOX ── */
.insight-box {
margin: 40px 0;
padding: 24px 28px;
background: var(–surface);
border: 1px solid var(–accent-border);
border-left: 3px solid var(–accent);
border-radius: 4px;
}
.insight-box h3 {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 12px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 10px;
}
.insight-box p {
font-size: 15px;
color: var(–text-secondary);
line-height: 1.7;
}
.insight-box strong { color: var(–text); font-weight: 600; }

/* ── SECTION ── */
.section {
padding: 48px 0;
border-bottom: 1px solid var(–border);
opacity: 0;
transform: translateY(20px);
animation: fadeIn 0.5s ease-out forwards;
}
.section:nth-child(2) { animation-delay: 0.1s; }
.section:nth-child(3) { animation-delay: 0.2s; }
.section:nth-child(4) { animation-delay: 0.3s; }
.section:nth-child(5) { animation-delay: 0.4s; }
.section:nth-child(6) { animation-delay: 0.5s; }

@keyframes fadeIn {
to { opacity: 1; transform: translateY(0); }
}

.section-label {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 11px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–text-muted);
margin-bottom: 8px;
}
.section h2 {
font-size: 26px;
font-weight: 700;
letter-spacing: -0.5px;
margin-bottom: 16px;
}
.section-desc {
font-size: 15px;
color: var(–text-secondary);
max-width: 720px;
margin-bottom: 32px;
line-height: 1.7;
}

/* ── MEDALLION FLOW ── */
.medallion-flow {
display: grid;
grid-template-columns: 1fr auto 1fr auto 1fr;
gap: 0;
align-items: stretch;
margin: 32px 0;
}
.medallion-layer {
padding: 28px 24px;
border-radius: 6px;
position: relative;
}
.medallion-layer.bronze {
background: var(–bronze-bg);
border: 1px solid var(–bronze-border);
}
.medallion-layer.silver {
background: var(–silver-bg);
border: 1px solid var(–silver-border);
}
.medallion-layer.gold {
background: var(–gold-bg);
border: 1px solid var(–gold-border);
}
.layer-badge {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 10px;
letter-spacing: 2px;
text-transform: uppercase;
font-weight: 700;
margin-bottom: 6px;
}
.bronze .layer-badge { color: var(–bronze); }
.silver .layer-badge { color: var(–silver); }
.gold .layer-badge { color: var(–gold); }

.layer-title {
font-size: 18px;
font-weight: 700;
margin-bottom: 4px;
}
.layer-subtitle {
font-size: 12px;
color: var(–text-muted);
font-family: ‘IBM Plex Mono’, monospace;
margin-bottom: 14px;
}
.layer-agents {
list-style: none;
display: flex;
flex-direction: column;
gap: 8px;
}
.layer-agents li {
font-size: 13px;
color: var(–text-secondary);
padding: 8px 10px;
background: rgba(255,255,255,0.03);
border-radius: 4px;
border-left: 2px solid transparent;
transition: all 0.2s;
}
.layer-agents li:hover {
background: rgba(255,255,255,0.06);
transform: translateX(2px);
}
.bronze .layer-agents li { border-left-color: var(–bronze); }
.silver .layer-agents li { border-left-color: var(–silver); }
.gold .layer-agents li { border-left-color: var(–gold); }

.agent-tag {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 10px;
font-weight: 600;
padding: 2px 6px;
border-radius: 3px;
margin-right: 6px;
display: inline-block;
}
.tag-llm {
background: var(–purple-bg);
color: var(–purple);
border: 1px solid rgba(167,139,250,0.2);
}
.tag-det {
background: var(–accent-bg);
color: var(–accent);
border: 1px solid rgba(78,205,196,0.2);
}
.tag-ml {
background: rgba(107,203,119,0.08);
color: var(–green);
border: 1px solid rgba(107,203,119,0.2);
}
.tag-human {
background: var(–red-bg);
color: var(–red);
border: 1px solid rgba(255,107,107,0.2);
}

.flow-arrow {
display: flex;
align-items: center;
justify-content: center;
padding: 0 8px;
color: var(–text-muted);
font-size: 20px;
}

/* ── DATA VAULT MAPPING TABLE ── */
