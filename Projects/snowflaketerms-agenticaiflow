<script>

// ─── ROOT ────────────────────────────────────────────────────────────────────

function commandCenter() {
  return {
    activeTab: 'billing',
    sidebarOpen: true,
    toast: false,
    navItems: [
      { key: 'billing',  label: 'Commercials & Billing',  icon: 'dollar-sign' },
      { key: 'rfp',      label: 'RFP Vault',              icon: 'layers' },
      { key: 'pipeline', label: 'Client Change Pipeline',  icon: 'git-branch' },
      { key: 'sales',    label: 'Sales Pipeline',          icon: 'trending-up' },
      { key: 'products', label: 'Products & Models',        icon: 'box' },
      { key: 'sweetspot', label: 'Sweet Spot Mapper',       icon: 'target' },
      { key: 'briefing', label: 'Incident SITREP',         icon: 'pen-tool' },
      { key: 'weekly',   label: 'Weekly Update',            icon: 'calendar-check' },
    ],
    get currentLabel() { return (this.navItems.find(n => n.key === this.activeTab) || {}).label || ''; },
    get metrics() {
      const b = loadData('billing', INITIAL_BILLING);
      const p = loadData('pipeline', INITIAL_PIPELINE);
      const s = loadData('sales', INITIAL_SALES);
      const pr = loadData('products', INITIAL_PRODUCTS);
      const leak = b.filter(r => r.fee > 0 && r.tasks / r.fee > TASK_THRESHOLD).length;
      const red = p.filter(r => r.blocker === 'Red').length;
      const pipeAum = s.filter(r => r.stage !== 'Won' && r.stage !== 'Lost').reduce((a,r) => a + (r.aum||0), 0);
      const prodInDev = pr.filter(r => r.stage !== 'Live' && r.stage !== 'Retired').length;
      return [
        { label: 'Active Incidents', value: red, accent: 'var(--red)', icon: 'alert-triangle' },
        { label: 'Sales Pipeline',   value: '€' + (pipeAum/1000).toFixed(1) + 'bn', accent: 'var(--purple)', icon: 'trending-up' },
        { label: 'Products In Dev',  value: prodInDev, accent: 'var(--blue)', icon: 'box' },
        { label: 'Risk Level', value: red > 2 ? 'HIGH' : red > 0 ? 'MEDIUM' : 'LOW', accent: red > 2 ? 'var(--red)' : red > 0 ? 'var(--yellow)' : 'var(--green)', icon: 'shield' },
      ];
    },
    showToast() { this.toast = true; setTimeout(() => this.toast = false, 2000); },
    copyText(t) { navigator.clipboard.writeText(t); this.showToast(); },

    exportAllData() { exportAllData(); this.showToast(); },
    async handleImport(event) {
      const file = event.target.files[0];
      if (!file) return;
      try {
        const ts = await importDataFromFile(file);
        alert('Data imported successfully (exported: ' + ts + '). The page will now reload.');
        location.reload();
      } catch (err) { alert('Import failed: ' + err.message); }
      event.target.value = '';
    },
    init() {
      this.$watch('activeTab', () => this.$nextTick(() => lucide.createIcons()));
      this.$watch('sidebarOpen', () => this.$nextTick(() => lucide.createIcons()));
      this.$nextTick(() => lucide.createIcons());
    }
  };
}

// ─── BILLING ─────────────────────────────────────────────────────────────────

function billingSection() {
  return {
    rows: loadData('billing', INITIAL_BILLING),
    newRow: { client: '', fee: '', tasks: '', lastReview: '' },
    ratio(r)     { return r.fee > 0 ? r.tasks / r.fee : 0; },
    isLeaking(r) { return this.ratio(r) > TASK_THRESHOLD; },
    isOverdue(r) { return monthsSince(r.lastReview) >= MONTHS_OVERDUE; },
    get leakingRows() { return this.rows.filter(r => this.isLeaking(r)); },
    get overdueRows() { return this.rows.filter(r => this.isOverdue(r)); },
    get totalLeakageK() { return (this.leakingRows.reduce((s,r) => s + (r.tasks/r.fee - TASK_THRESHOLD)*r.fee*100, 0)/1000).toFixed(1); },
    addRow() {
      if (!this.newRow.client) return;
      this.rows.push({ id: Date.now(), client: this.newRow.client, fee: parseFloat(this.newRow.fee)||0, tasks: parseInt(this.newRow.tasks)||0, lastReview: this.newRow.lastReview || todayISO() });
      this.newRow = { client: '', fee: '', tasks: '', lastReview: '' };
      this.persist();
    },
    persist() { saveData('billing', this.rows); },
    monthsSince(d) { return monthsSince(d); },
    init() { this.$nextTick(() => lucide.createIcons()); }
  };
}

// ─── RFP VAULT ───────────────────────────────────────────────────────────────

function rfpVault() {
  return {
    modules: loadData('rfp', INITIAL_RFP_MODULES),
    search: '', filter: 'All',
    newModule: { category: 'Tech', question: '', answer: '' },
    get categories() { return ['All', ...new Set(this.modules.map(m => m.category))]; },
    get filteredModules() {
      return this.modules.filter(m => {
        if (this.filter !== 'All' && m.category !== this.filter) return false;
        if (this.search) { const q = this.search.toLowerCase(); if (!m.question.toLowerCase().includes(q) && !m.answer.toLowerCase().includes(q)) return false; }
        return true;
      });
    },
    catColor(c) { return c==='Tech'?'var(--blue)':c==='ESG'?'var(--green)':c==='Ops'?'var(--yellow)':'var(--purple)'; },
    copyText(t) { navigator.clipboard.writeText(t); window.dispatchEvent(new CustomEvent('show-toast')); },
    addModule() {
      if (!this.newModule.question || !this.newModule.answer) return;
      this.modules.push({ id: Date.now(), ...this.newModule });
      this.newModule = { category: 'Tech', question: '', answer: '' };
      this.persistRfp();
    },
    persistRfp() { saveData('rfp', this.modules); },
    init() { this.$nextTick(() => lucide.createIcons()); }
  };
}

// ─── PIPELINE ────────────────────────────────────────────────────────────────

function pipelineSection() {
  return {
    rows: loadData('pipeline', INITIAL_PIPELINE),
    cycleBlocker(r) { const o=['Green','Yellow','Red']; r.blocker=o[(o.indexOf(r.blocker)+1)%3]; this.persistPipeline(); },
    get blockerCounts() { const c={Legal:0,Ops:0,Tech:0,Client:0}; this.rows.forEach(r=>{if(r.blocker!=='Green')c[r.stakeholder]=(c[r.stakeholder]||0)+1;}); return c; },
    get stageCounts() { const c={Onboarding:0,Launch:0,Liquidation:0}; this.rows.forEach(r=>c[r.stage]=(c[r.stage]||0)+1); return c; },
    get redCount() { return this.rows.filter(r=>r.blocker==='Red').length; },
    persistPipeline() { saveData('pipeline', this.rows); },
    init() { this.$nextTick(() => lucide.createIcons()); }
  };
}

// ─── SALES PIPELINE (NEW) ────────────────────────────────────────────────────

function salesSection() {
  return {
    rows: loadData('sales', INITIAL_SALES),
    newDeal: { prospect:'', contact:'', aum:'', stage:'Prospect', probability:'25', nextAction:'', nextDate:'' },

    get totalPipelineM() { return this.rows.filter(r=>r.stage!=='Lost').reduce((a,r)=>a+(r.aum||0),0).toFixed(0); },
    get weightedValueM() { return this.rows.filter(r=>r.stage!=='Lost'&&r.stage!=='Won').reduce((a,r)=>a+(r.aum||0)*(r.probability||0)/100,0).toFixed(0); },
    get wonCount()    { return this.rows.filter(r=>r.stage==='Won').length; },
    get activeDeals() { return this.rows.filter(r=>r.stage!=='Won'&&r.stage!=='Lost').length; },

    stageCount(s) { return this.rows.filter(r=>r.stage===s).length; },
    stageAum(s)   { return this.rows.filter(r=>r.stage===s).reduce((a,r)=>a+(r.aum||0),0).toFixed(0); },

    addDeal() {
      if (!this.newDeal.prospect) return;
      this.rows.push({ id: Date.now(), prospect: this.newDeal.prospect, contact: this.newDeal.contact, aum: parseFloat(this.newDeal.aum)||0, stage: this.newDeal.stage, probability: parseInt(this.newDeal.probability)||0, nextAction: this.newDeal.nextAction, nextDate: this.newDeal.nextDate || todayISO(), notes: '' });
      this.newDeal = { prospect:'', contact:'', aum:'', stage:'Prospect', probability:'25', nextAction:'', nextDate:'' };
      this.persist();
    },
    persist() { saveData('sales', this.rows); },
    init() { this.$nextTick(() => lucide.createIcons()); }
  };
}

// ─── PRODUCTS & MODELS (NEW) ─────────────────────────────────────────────────

function productsSection() {
  return {
    rows: loadData('products', INITIAL_PRODUCTS),
    filter: 'All',
    typeFilter: 'All',
    newProduct: { name:'', type:'Platform', stage:'Research', owner:'', target:'' },

    get typeFilters() { return ['All', ...new Set(this.rows.map(r => r.type))]; },

    get filteredRows() {
      return this.rows.filter(r => {
        if (this.filter !== 'All' && r.stage !== this.filter) return false;
        if (this.typeFilter !== 'All' && r.type !== this.typeFilter) return false;
        return true;
      });
    },

    get blockedProducts() { return this.rows.filter(r => r.blockers && r.blockers.trim() && r.stage !== 'Live' && r.stage !== 'Retired'); },

    get avgProgress() {
      const active = this.rows.filter(r => r.stage !== 'Live' && r.stage !== 'Retired');
      if (!active.length) return 0;
      return Math.round(active.reduce((a,r) => a + (r.progress||0), 0) / active.length);
    },

    countStage(s) { return this.rows.filter(r => r.stage === s).length; },

    cyclePriority(r) {
      const o = ['Low','Medium','High'];
      r.priority = o[(o.indexOf(r.priority)+1)%3];
      this.persist();
    },

    addProduct() {
      if (!this.newProduct.name) return;
      this.rows.push({
        id: Date.now(),
        name: this.newProduct.name,
        type: this.newProduct.type,
        stage: this.newProduct.stage,
        owner: this.newProduct.owner || 'TBD',
        target: this.newProduct.target || 'TBD',
        priority: 'Medium',
        blockers: '',
        progress: 0,
      });
      this.newProduct = { name:'', type:'Platform', stage:'Research', owner:'', target:'' };
      this.persist();
    },

    persist() { saveData('products', this.rows); },
    init() { this.$nextTick(() => lucide.createIcons()); }
  };
}

// ─── SWEET SPOT MAPPER ───────────────────────────────────────────────────────

function sweetSpotSection() {
  return {
    dimensions: CAPABILITY_DIMENSIONS,
    activeDimension: 'fundTypes',
    clients: loadData('clientmap', INITIAL_CLIENT_MAP),
    newClient: { client:'', fundType:'', strategy:'', clientType:'Institutional Investors', geo:'Ireland', zone:'sweet-spot' },

    get dimensionKeys() { return Object.keys(this.dimensions); },

    // Calculate what % of cells in active dimension are a given level
    strengthPct(level) {
      const dim = this.dimensions[this.activeDimension];
      let total = 0, match = 0;
      dim.rows.forEach(r => r.ratings.forEach(rating => { total++; if (rating === level) match++; }));
      return total ? Math.round(match / total * 100) : 0;
    },

    clientsByZone(zone) { return this.clients.filter(c => c.zone === zone); },

    addClient() {
      if (!this.newClient.client) return;
      this.clients.push({
        id: Date.now(),
        client: this.newClient.client,
        fundType: this.newClient.fundType || 'TBD',
        strategy: this.newClient.strategy || 'TBD',
        clientType: this.newClient.clientType,
        geo: this.newClient.geo || 'Ireland',
        zone: this.newClient.zone,
      });
      this.newClient = { client:'', fundType:'', strategy:'', clientType:'Institutional Investors', geo:'Ireland', zone:'sweet-spot' };
      this.persistClients();
    },

    persistClients() { saveData('clientmap', this.clients); },
    init() { this.$nextTick(() => lucide.createIcons()); }
  };
}

// ─── BRIEFING ────────────────────────────────────────────────────────────────

function briefingSection() {
  return {
    raw: "Ops forgot to check the cash rec again. The client is unhappy because the NAV was late. We're short-staffed and using a manual process that keeps breaking.",
    template: 'Strategic / Innovative', output: '',
    get templateNames() { return Object.keys(STRATEGIC_TEMPLATES); },
    transform() {
      const t = STRATEGIC_TEMPLATES[this.template];
      if (!t || !this.raw.trim()) return;
      let text = this.raw;
      t.transforms.forEach(([re,rep]) => { text = text.replace(re, rep); });
      text = text.replace(/(^\s*\w|[.!?]\s*\w)/g, c => c.toUpperCase());
      this.output = t.prefix + '\n' + '─'.repeat(50) + '\n\n' + text + '\n\n' + t.suffix;
    },
    copyText(t) { navigator.clipboard.writeText(t); window.dispatchEvent(new CustomEvent('show-toast')); },
    init() {
      this.$nextTick(() => lucide.createIcons());
      this.$watch('template', () => { if (this.raw.trim()) this.transform(); });
    }
  };
}

// ─── WEEKLY UPDATE (NEW) ─────────────────────────────────────────────────────

function weeklySection() {
  return {
    output: '',
    lastGenerated: '',

    generate() {
      const billing  = loadData('billing',  INITIAL_BILLING);
      const pipeline = loadData('pipeline', INITIAL_PIPELINE);
      const sales    = loadData('sales',    INITIAL_SALES);
      const rfp      = loadData('rfp',      INITIAL_RFP_MODULES);
      const products = loadData('products', INITIAL_PRODUCTS);
      const now      = new Date();
      const weekOf   = now.toLocaleDateString('en-IE', { day:'numeric', month:'long', year:'numeric' });

      // Billing metrics
      const leaking  = billing.filter(r => r.fee>0 && r.tasks/r.fee > TASK_THRESHOLD);
      const overdue  = billing.filter(r => monthsSince(r.lastReview) >= MONTHS_OVERDUE);
      const totalLeak= leaking.reduce((s,r) => s + (r.tasks/r.fee - TASK_THRESHOLD)*r.fee*100, 0);

      // Pipeline metrics
      const redPipe  = pipeline.filter(r => r.blocker==='Red');
      const yellowPipe = pipeline.filter(r => r.blocker==='Yellow');
      const blockers = {};
      pipeline.forEach(r => { if (r.blocker!=='Green') blockers[r.stakeholder] = (blockers[r.stakeholder]||0)+1; });

      // Sales metrics
      const activeS  = sales.filter(r => r.stage!=='Won' && r.stage!=='Lost');
      const wonS     = sales.filter(r => r.stage==='Won');
      const pipeAum  = activeS.reduce((a,r)=>a+(r.aum||0),0);
      const weightV  = activeS.reduce((a,r)=>a+(r.aum||0)*(r.probability||0)/100,0);

      let lines = [];
      lines.push('WEEKLY MANAGEMENT UPDATE');
      lines.push('Week of ' + weekOf);
      lines.push('═'.repeat(56));
      lines.push('');

      // 1. Commercial Health
      lines.push('1. COMMERCIAL HEALTH');
      lines.push('─'.repeat(40));
      lines.push('Clients tracked: ' + billing.length);
      lines.push('Revenue leakage flagged: ' + leaking.length + ' client' + (leaking.length!==1?'s':''));
      if (leaking.length) {
        lines.push('  Leaking clients: ' + leaking.map(r => r.client + ' (ratio: ' + (r.tasks/r.fee).toFixed(1) + ')').join(', '));
        lines.push('  Estimated leakage: €' + (totalLeak/1000).toFixed(1) + 'k');
      }
      lines.push('Fee reviews overdue (>18mo): ' + overdue.length);
      if (overdue.length) lines.push('  Overdue: ' + overdue.map(r => r.client + ' (' + monthsSince(r.lastReview) + 'mo)').join(', '));
      lines.push('');

      // 2. Sales Pipeline
      lines.push('2. SALES PIPELINE');
      lines.push('─'.repeat(40));
      lines.push('Total pipeline AUM: €' + pipeAum + 'm (' + activeS.length + ' active deal' + (activeS.length!==1?'s':'') + ')');
      lines.push('Probability-weighted value: €' + weightV.toFixed(0) + 'm');
      lines.push('Won this period: ' + wonS.length);
      if (activeS.length) {
        lines.push('Active deals:');
        activeS.forEach(r => lines.push('  • ' + r.prospect + ' — €' + r.aum + 'm — ' + r.stage + ' (' + r.probability + '%) — Next: ' + r.nextAction));
      }
      lines.push('');

      // 3. Change Pipeline
      lines.push('3. CLIENT CHANGE PIPELINE');
      lines.push('─'.repeat(40));
      lines.push('Active projects: ' + pipeline.length);
      lines.push('Critical (Red): ' + redPipe.length + ' | Amber (Yellow): ' + yellowPipe.length);
      if (redPipe.length) lines.push('  Red blockers: ' + redPipe.map(r => r.project + ' [' + r.stakeholder + ']').join(', '));
      const topBlocker = Object.entries(blockers).sort((a,b)=>b[1]-a[1])[0];
      if (topBlocker && topBlocker[1]>1) lines.push('  Primary bottleneck: ' + topBlocker[0] + ' (' + topBlocker[1] + ' projects blocked)');
      lines.push('');

      // 4. RFP Readiness
      lines.push('4. RFP READINESS');
      lines.push('─'.repeat(40));
      lines.push('Knowledge modules available: ' + rfp.length);
      const cats = {};
      rfp.forEach(r => cats[r.category] = (cats[r.category]||0)+1);
      lines.push('Coverage: ' + Object.entries(cats).map(([k,v])=>k+': '+v).join(' | '));
      lines.push('');

      // 5. Products & Models
      lines.push('5. PRODUCTS & MODELS');
      lines.push('─'.repeat(40));
      const prodActive = products.filter(r => r.stage !== 'Live' && r.stage !== 'Retired');
      const prodLive   = products.filter(r => r.stage === 'Live');
      const prodHigh   = prodActive.filter(r => r.priority === 'High');
      const avgProg    = prodActive.length ? Math.round(prodActive.reduce((a,r) => a + (r.progress||0), 0) / prodActive.length) : 0;
      lines.push('Active products in development: ' + prodActive.length + ' | Live: ' + prodLive.length);
      lines.push('Average progress (excl. Live): ' + avgProg + '%');
      if (prodHigh.length) {
        lines.push('High-priority items:');
        prodHigh.forEach(r => lines.push('  • ' + r.name + ' — ' + r.stage + ' — ' + r.progress + '% — Target: ' + r.target));
      }
      const blocked = products.filter(r => r.blockers && r.blockers.trim() && r.stage !== 'Live' && r.stage !== 'Retired');
      if (blocked.length) {
        lines.push('Products with active blockers: ' + blocked.length);
        blocked.forEach(r => lines.push('  • ' + r.name + ': ' + r.blockers));
      }
      lines.push('');

      // 6. Client Sweet Spot
      const cmap = loadData('clientmap', INITIAL_CLIENT_MAP);
      const sweet = cmap.filter(c => c.zone === 'sweet-spot');
      const edge  = cmap.filter(c => c.zone === 'near-edge');
      const off   = cmap.filter(c => c.zone === 'off-target');
      lines.push('6. CLIENT POSITIONING');
      lines.push('─'.repeat(40));
      lines.push('Sweet spot: ' + sweet.length + ' | Near edge: ' + edge.length + ' | Off target: ' + off.length);
      if (off.length) lines.push('Off-target clients requiring review: ' + off.map(c => c.client).join(', '));
      lines.push('');

      // 7. Risk Summary
      lines.push('7. RISK SUMMARY');
      lines.push('─'.repeat(40));
      const riskLevel = redPipe.length > 2 ? 'HIGH' : redPipe.length > 0 ? 'MEDIUM' : 'LOW';
      lines.push('Overall risk level: ' + riskLevel);
      if (leaking.length) lines.push('Revenue risk: ' + leaking.length + ' client' + (leaking.length!==1?'s':'') + ' flagged for leakage');
      if (overdue.length) lines.push('Pricing risk: ' + overdue.length + ' fee review' + (overdue.length!==1?'s':'') + ' overdue');
      if (redPipe.length) lines.push('Delivery risk: ' + redPipe.length + ' critical blocker' + (redPipe.length!==1?'s':''));
      lines.push('');
      lines.push('═'.repeat(56));
      lines.push('Generated: ' + now.toLocaleString('en-IE'));

      this.output = lines.join('\n');
      this.lastGenerated = now.toLocaleTimeString('en-IE', { hour:'2-digit', minute:'2-digit' });
    },

    copyText(t) { navigator.clipboard.writeText(t); window.dispatchEvent(new CustomEvent('show-toast')); },
    init() { this.$nextTick(() => lucide.createIcons()); }
  };
}

// ─── GLOBAL TOAST HANDLER ────────────────────────────────────────────────────
window.addEventListener('show-toast', () => {
  const el = document.querySelector('[x-data="commandCenter()"]');
  if (el && el._x_dataStack) { const d = el._x_dataStack[0]; d.toast = true; setTimeout(()=>d.toast=false, 2000); }
});

// ─── LUCIDE: ensure icons render on all DOM changes ──────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  lucide.createIcons();
  new MutationObserver(() => lucide.createIcons()).observe(document.body, { childList: true, subtree: true });
});
</script>

