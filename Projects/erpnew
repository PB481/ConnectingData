<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agentic ERP — Client Change Request Flow</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=IBM+Plex+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #faf7f2;
    --bg-panel: #ffffff;
    --bg-sunken: #f1ede5;
    --ink: #1a1714;
    --ink-soft: #4a443c;
    --ink-mute: #8a8378;
    --line: #d8d2c4;
    --line-soft: #e8e3d6;
    --accent: #7a2418;
    --accent-soft: #c0644f;
    --teal: #1f5d5e;
    --gold: #b08831;
    --green: #4a6b3a;
    --warn: #a85a1f;
    --shadow-1: 0 1px 2px rgba(26,23,20,0.04), 0 1px 1px rgba(26,23,20,0.02);
    --shadow-2: 0 4px 12px rgba(26,23,20,0.06), 0 2px 4px rgba(26,23,20,0.03);
    --shadow-3: 0 12px 32px rgba(26,23,20,0.08), 0 4px 8px rgba(26,23,20,0.04);
    --serif: 'Fraunces', Georgia, serif;
    --sans: 'IBM Plex Sans', -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
background: var(–bg);
color: var(–ink);
font-family: var(–sans);
font-size: 14px;
line-height: 1.5;
-webkit-font-smoothing: antialiased;
overflow-x: hidden;
}

/* Decorative grid overlay */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image:
linear-gradient(var(–line-soft) 1px, transparent 1px),
linear-gradient(90deg, var(–line-soft) 1px, transparent 1px);
background-size: 64px 64px;
opacity: 0.35;
pointer-events: none;
z-index: 0;
}

.container {
position: relative;
z-index: 1;
max-width: 1440px;
margin: 0 auto;
padding: 32px 40px 80px;
}

/* ===== HEADER ===== */
header {
display: flex;
justify-content: space-between;
align-items: flex-end;
border-bottom: 1px solid var(–ink);
padding-bottom: 24px;
margin-bottom: 32px;
}

.brand {
display: flex;
flex-direction: column;
gap: 4px;
}

.brand-eyebrow {
font-family: var(–mono);
font-size: 10px;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–ink-mute);
display: flex;
align-items: center;
gap: 12px;
}

.brand-eyebrow::before {
content: ‘’;
width: 6px;
height: 6px;
border-radius: 50%;
background: var(–accent);
display: inline-block;
}

.brand-title {
font-family: var(–serif);
font-size: 38px;
font-weight: 400;
letter-spacing: -0.02em;
line-height: 1;
}

.brand-title em {
font-style: italic;
color: var(–accent);
font-weight: 300;
}

.brand-sub {
font-family: var(–serif);
font-style: italic;
font-size: 15px;
color: var(–ink-soft);
margin-top: 6px;
}

.header-meta {
display: flex;
gap: 24px;
font-family: var(–mono);
font-size: 11px;
color: var(–ink-mute);
text-transform: uppercase;
letter-spacing: 0.1em;
}

.header-meta div span {
display: block;
color: var(–ink);
font-size: 14px;
text-transform: none;
letter-spacing: 0;
margin-top: 2px;
}

/* ===== INTRO ===== */
.intro {
display: grid;
grid-template-columns: 1.4fr 1fr;
gap: 48px;
margin-bottom: 40px;
padding-bottom: 32px;
border-bottom: 1px solid var(–line);
}

.intro-lead {
font-family: var(–serif);
font-size: 22px;
line-height: 1.4;
font-weight: 300;
color: var(–ink);
}

.intro-lead em {
font-style: italic;
color: var(–accent);
}

.intro-instructions {
font-size: 13px;
color: var(–ink-soft);
}

.intro-instructions h4 {
font-family: var(–mono);
font-size: 10px;
text-transform: uppercase;
letter-spacing: 0.15em;
color: var(–ink-mute);
margin-bottom: 8px;
font-weight: 500;
}

.intro-instructions ol {
list-style: none;
counter-reset: step;
padding: 0;
}

.intro-instructions li {
counter-increment: step;
padding-left: 28px;
position: relative;
margin-bottom: 6px;
}

.intro-instructions li::before {
content: counter(step);
position: absolute;
left: 0;
top: 0;
font-family: var(–mono);
font-size: 11px;
color: var(–accent);
font-weight: 600;
}

/* ===== CASE SELECTOR ===== */
.section-head {
display: flex;
justify-content: space-between;
align-items: baseline;
margin-bottom: 16px;
}

.section-title {
font-family: var(–serif);
font-size: 18px;
font-weight: 600;
letter-spacing: -0.01em;
}

.section-title-num {
font-family: var(–mono);
font-size: 11px;
color: var(–ink-mute);
margin-right: 12px;
}

.section-aside {
font-family: var(–mono);
font-size: 11px;
color: var(–ink-mute);
text-transform: uppercase;
letter-spacing: 0.1em;
}

.case-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 12px;
margin-bottom: 12px;
}

.case-grid.anti {
grid-template-columns: repeat(3, 1fr);
margin-bottom: 32px;
}

.case-card {
background: var(–bg-panel);
border: 1px solid var(–line);
padding: 14px 14px 12px;
cursor: pointer;
transition: all 0.2s ease;
position: relative;
overflow: hidden;
}

.case-card:hover {
border-color: var(–ink);
transform: translateY(-1px);
box-shadow: var(–shadow-2);
}

.case-card.active {
background: var(–ink);
color: var(–bg);
border-color: var(–ink);
}

.case-card.active .case-num,
.case-card.active .case-tag { color: var(–bg); opacity: 0.7; }

.case-card.anti {
background: var(–bg-sunken);
border-style: dashed;
border-color: var(–line);
}

.case-card.anti.active {
background: var(–accent);
color: var(–bg);
border-style: solid;
border-color: var(–accent);
}

.case-card.anti.active .case-num,
.case-card.anti.active .case-tag { color: var(–bg); }

.case-num {
font-family: var(–mono);
font-size: 10px;
color: var(–ink-mute);
letter-spacing: 0.1em;
margin-bottom: 4px;
}

.case-title {
font-family: var(–serif);
font-size: 14px;
font-weight: 600;
line-height: 1.25;
margin-bottom: 6px;
}

.case-tag {
font-family: var(–mono);
font-size: 9px;
color: var(–ink-mute);
text-transform: uppercase;
letter-spacing: 0.1em;
}

/* ===== STAGE PANEL ===== */
.controls {
display: flex;
align-items: center;
gap: 16px;
margin-bottom: 20px;
padding: 14px 18px;
background: var(–ink);
color: var(–bg);
}

.btn-play {
background: var(–bg);
color: var(–ink);
border: none;
padding: 8px 18px;
font-family: var(–mono);
font-size: 11px;
text-transform: uppercase;
letter-spacing: 0.12em;
cursor: pointer;
font-weight: 600;
transition: all 0.2s;
}

.btn-play:hover { background: var(–accent-soft); }
.btn-play:disabled { opacity: 0.4; cursor: not-allowed; }

.btn-reset {
background: transparent;
color: var(–bg);
border: 1px solid rgba(250,247,242,0.3);
padding: 8px 14px;
font-family: var(–mono);
font-size: 11px;
text-transform: uppercase;
letter-spacing: 0.12em;
cursor: pointer;
}

.controls-status {
flex: 1;
font-family: var(–mono);
font-size: 11px;
text-transform: uppercase;
letter-spacing: 0.1em;
opacity: 0.7;
}

.speed-select {
background: transparent;
border: 1px solid rgba(250,247,242,0.3);
color: var(–bg);
font-family: var(–mono);
font-size: 11px;
padding: 6px 8px;
text-transform: uppercase;
letter-spacing: 0.1em;
}

/* ===== FLOW CANVAS ===== */
.flow-wrap {
display: grid;
grid-template-columns: 1fr 320px;
gap: 24px;
margin-bottom: 32px;
}

.flow-canvas {
background: var(–bg-panel);
border: 1px solid var(–line);
padding: 32px 28px 28px;
position: relative;
min-height: 540px;
}

.flow-canvas-header {
display: flex;
justify-content: space-between;
align-items: baseline;
margin-bottom: 20px;
padding-bottom: 12px;
border-bottom: 1px solid var(–line-soft);
}

.flow-canvas-title {
font-family: var(–serif);
font-size: 16px;
font-weight: 600;
}

.flow-canvas-meta {
font-family: var(–mono);
font-size: 10px;
color: var(–ink-mute);
letter-spacing: 0.1em;
text-transform: uppercase;
}

/* Stage row: 11 stages laid out as a horizontal flow */
.stages-svg-wrap { width: 100%; position: relative; }
.stages-svg { width: 100%; height: auto; display: block; }

/* Side panel narrative */
.narrative-panel {
background: var(–bg-panel);
border: 1px solid var(–line);
padding: 24px;
display: flex;
flex-direction: column;
min-height: 540px;
}

.narr-stage-num {
font-family: var(–mono);
font-size: 10px;
color: var(–accent);
letter-spacing: 0.18em;
text-transform: uppercase;
margin-bottom: 6px;
font-weight: 600;
}

.narr-stage-title {
font-family: var(–serif);
font-size: 22px;
font-weight: 600;
letter-spacing: -0.015em;
margin-bottom: 14px;
line-height: 1.15;
}

.narr-stage-arch {
font-size: 12px;
color: var(–ink-mute);
font-style: italic;
margin-bottom: 16px;
padding-bottom: 12px;
border-bottom: 1px dotted var(–line);
line-height: 1.4;
}

.narr-stage-body {
font-size: 13px;
color: var(–ink-soft);
line-height: 1.55;
flex: 1;
}

.narr-stage-body strong { color: var(–ink); font-weight: 600; }

.narr-tools {
margin-top: 16px;
padding-top: 14px;
border-top: 1px solid var(–line-soft);
}

.narr-tools-label {
font-family: var(–mono);
font-size: 9px;
text-transform: uppercase;
letter-spacing: 0.15em;
color: var(–ink-mute);
margin-bottom: 8px;
}

.narr-tool {
display: inline-block;
font-family: var(–mono);
font-size: 10px;
padding: 3px 8px;
border: 1px solid var(–line);
margin: 0 4px 4px 0;
color: var(–ink-soft);
background: var(–bg-sunken);
}

.narr-tool.active {
background: var(–teal);
color: var(–bg);
border-color: var(–teal);
}

/* Empty narrative state */
.narr-empty {
height: 100%;
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
color: var(–ink-mute);
text-align: center;
}

.narr-empty-icon {
font-family: var(–serif);
font-style: italic;
font-size: 48px;
color: var(–line);
margin-bottom: 12px;
}

.narr-empty-text {
font-family: var(–serif);
font-style: italic;
font-size: 15px;
max-width: 220px;
line-height: 1.4;
}

/* ===== STATS ROW ===== */
.stats {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 16px;
margin-bottom: 32px;
}

.stat {
background: var(–bg-panel);
border: 1px solid var(–line);
padding: 18px 20px;
position: relative;
overflow: hidden;
}

.stat::before {
content: ‘’;
position: absolute;
left: 0;
top: 0;
width: 3px;
height: 100%;
background: var(–ink);
}

.stat.accent::before { background: var(–accent); }
.stat.teal::before { background: var(–teal); }
.stat.gold::before { background: var(–gold); }

.stat-label {
font-family: var(–mono);
font-size: 9px;
text-transform: uppercase;
letter-spacing: 0.15em;
color: var(–ink-mute);
margin-bottom: 8px;
}

.stat-value {
font-family: var(–serif);
font-size: 32px;
font-weight: 400;
line-height: 1;
letter-spacing: -0.02em;
}

.stat-value .unit {
font-size: 14px;
color: var(–ink-mute);
margin-left: 4px;
font-style: italic;
}

.stat-detail {
font-size: 11px;
color: var(–ink-mute);
margin-top: 6px;
font-family: var(–mono);
}

/* ===== MODAL ===== */
.modal-overlay {
position: fixed;
inset: 0;
background: rgba(26,23,20,0.5);
display: none;
z-index: 100;
align-items: center;
justify-content: center;
padding: 40px;
}

.modal-overlay.open { display: flex; }

.modal {
background: var(–bg);
max-width: 640px;
width: 100%;
padding: 40px;
border: 1px solid var(–ink);
box-shadow: var(–shadow-3);
max-height: 80vh;
overflow-y: auto;
position: relative;
}

.modal-eyebrow {
font-family: var(–mono);
font-size: 10px;
text-transform: uppercase;
letter-spacing: 0.18em;
color: var(–accent);
margin-bottom: 8px;
}

.modal-title {
font-family: var(–serif);
font-size: 28px;
font-weight: 600;
letter-spacing: -0.02em;
margin-bottom: 20px;
line-height: 1.1;
}

.modal-close {
position: absolute;
top: 24px;
right: 24px;
background: transparent;
border: 1px solid var(–line);
width: 32px;
height: 32px;
cursor: pointer;
font-family: var(–mono);
font-size: 14px;
color: var(–ink-soft);
}

.modal-section {
margin-bottom: 18px;
}

.modal-section h4 {
font-family: var(–mono);
font-size: 10px;
text-transform: uppercase;
letter-spacing: 0.15em;
color: var(–ink-mute);
margin-bottom: 8px;
font-weight: 500;
}

.modal-section p {
font-size: 14px;
color: var(–ink-soft);
line-height: 1.55;
}

.modal-section p strong { color: var(–ink); }

/* ===== FOOTER ===== */
footer {
margin-top: 80px;
padding-top: 24px;
border-top: 1px solid var(–line);
display: flex;
justify-content: space-between;
align-items: center;
font-family: var(–mono);
font-size: 10px;
color: var(–ink-mute);
text-transform: uppercase;
letter-spacing: 0.12em;
}

/* ===== ANIMATION CLASSES ===== */
@keyframes pulse-stage {
0%, 100% { transform: scale(1); }
50% { transform: scale(1.06); }
}

@keyframes orbit-glow {
0%, 100% { opacity: 0.4; }
50% { opacity: 1; }
}

/* Responsive */
@media (max-width: 1100px) {
.flow-wrap { grid-template-columns: 1fr; }
.case-grid { grid-template-columns: repeat(2, 1fr); }
.case-grid.anti { grid-template-columns: repeat(2, 1fr); }
.stats { grid-template-columns: repeat(2, 1fr); }
.intro { grid-template-columns: 1fr; gap: 24px; }
}
</style>

</head>
<body>
<div class="container">

  <!-- ===== HEADER ===== -->

  <header>
    <div class="brand">
      <div class="brand-eyebrow">Internal · Strategic Architecture</div>
      <h1 class="brand-title">Agentic ERP <em>— Client Change Request Flow</em></h1>
