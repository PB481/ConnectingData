  // Narrative panel
  const panel = document.getElementById('narrativePanel');
  panel.innerHTML = `
    <div class="narr-stage-num" style="color:#a85a1f;">${c.ref} · ${c.tag}</div>
    <div class="narr-stage-title">${c.title}</div>
    <div class="narr-stage-arch">${c.summary}</div>
    <div class="narr-stage-body">
      <p style="margin-bottom:12px;"><strong>Why this is refused:</strong> ${c.rejectReason}</p>
      <p style="margin-bottom:12px;"><strong>What happens instead:</strong> ${c.routeTo}</p>
      <p style="font-style:italic; color:var(--ink-mute);">Saying "no" to the wrong work is how the architecture stays defensible. Sprawl is the failure mode.</p>
    </div>
    <div class="narr-tools">
      <div class="narr-tools-label">Outcome</div>
      <div class="narr-tool" style="font-size:11px;">${c.bill}</div>
