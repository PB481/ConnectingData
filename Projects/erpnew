/* ===========================================================
   ANIMATION
   =========================================================== */

function play() {
  if (!activeCase || isPlaying) return;
  isPlaying = true;
  currentStageIdx = -1;
  document.getElementById('btnPlay').disabled = true;
  document.getElementById('controlStatus').textContent = 'Running flow…';

  resetStageVisuals();
  document.getElementById('statTokens').innerHTML = `0<span class="unit">k</span>`;

  const speed = parseInt(document.getElementById('speedSelect').value);
  advance(speed);
}

function advance(speed) {
  currentStageIdx++;
  if (currentStageIdx >= STAGES.length) {
    finish();
    return;
  }

  const stage = STAGES[currentStageIdx];
  const stageData = activeCase.stages[stage.id];

  // Move token to stage position
  moveTokenTo(STAGE_POSITIONS[currentStageIdx], speed * 0.4);

  // Highlight stage
  highlightStage(stage.id, stageData.skip);

  // Activate tools for this stage
  setTimeout(() => activateTools(stageData.tools || []), speed * 0.4);

  // Update narrative
  setTimeout(() => updateNarrative(stage, stageData), speed * 0.5);

  // Update token meter
  setTimeout(() => addTokens(activeCase.tokenProfile[currentStageIdx]), speed * 0.5);

  // Schedule next
  animTimer = setTimeout(() => advance(speed), speed);
}

function moveTokenTo(pos, dur) {
  const token = document.getElementById('token');
  token.setAttribute('opacity', '1');
  // Get current position
  const transform = token.getAttribute('transform') || 'translate(60,90)';
  const match = transform.match(/translate\(([\d.-]+),([\d.-]+)\)/);
  const fromX = match ? parseFloat(match[1]) : 60;
  const fromY = match ? parseFloat(match[2]) : 90;

  const start = performance.now();
  const animate = (t) => {
    const elapsed = t - start;
    const p = Math.min(elapsed / dur, 1);
    const eased = 1 - Math.pow(1 - p, 3);
    const x = fromX + (pos.x - fromX) * eased;
    const y = fromY + (pos.y - fromY) * eased;
    token.setAttribute('transform', `translate(${x},${y})`);
    if (p < 1) requestAnimationFrame(animate);
  };
  requestAnimationFrame(animate);
}

function highlightStage(stageId, isSkip) {
  document.querySelectorAll('.stage-node').forEach(g => {
    const rect = g.querySelector('.stage-rect');
    if (g.dataset.stageId === stageId) {
      if (isSkip) {
        rect.setAttribute('fill', '#f1ede5');
        rect.setAttribute('stroke', '#8a8378');
        rect.setAttribute('stroke-width', '1');
        rect.setAttribute('stroke-dasharray', '4,2');
      } else {
        rect.setAttribute('fill', '#1a1714');
        rect.setAttribute('stroke', '#1a1714');
        rect.setAttribute('stroke-width', '2');
        // text white
        g.querySelectorAll('text').forEach(t => {
          if (!t.classList.contains('stage-info')) t.setAttribute('fill', '#faf7f2');
        });
      }
      // Add a pulse animation
      g.style.animation = 'pulse-stage 0.6s ease-in-out';
      setTimeout(() => { g.style.animation = ''; }, 600);
    }
  });
}

function activateTools(toolIds) {
  document.querySelectorAll('.tool-node').forEach(g => {
    const rect = g.querySelector('.tool-rect');
    const label = g.querySelector('.tool-label');
    if (toolIds.includes(g.dataset.toolId)) {
      rect.setAttribute('fill', '#1f5d5e');
      rect.setAttribute('stroke', '#1f5d5e');
      label.setAttribute('fill', '#faf7f2');
      g.style.animation = 'orbit-glow 1.2s ease-in-out';
    } else {
      rect.setAttribute('fill', '#f1ede5');
      rect.setAttribute('stroke', '#d8d2c4');
      label.setAttribute('fill', '#4a443c');
      g.style.animation = '';
    }
  });
}

function updateNarrative(stage, stageData) {
  const panel = document.getElementById('narrativePanel');
  const toolNames = (stageData.tools || []).map(tid => TOOLS.find(t => t.id === tid)?.label || tid);
  const allTools = TOOLS.map(t => {
    const isActive = (stageData.tools || []).includes(t.id);
    return `<span class="narr-tool${isActive ? ' active' : ''}">${t.label}</span>`;
  }).join('');

  panel.innerHTML = `
    <div class="narr-stage-num">Stage ${stage.num} · ${activeCase.ref}</div>
    <div class="narr-stage-title">${stage.label}</div>
    <div class="narr-stage-arch">${stage.what}</div>
    <div class="narr-stage-body">${stageData.body}${stageData.skip ? '<p style="margin-top:10px; font-style:italic; color:var(--warn);"><strong>Stage skipped for this case.</strong> The architecture being honest about where verification doesn\'t apply is a feature, not a gap.</p>' : ''}</div>
    <div class="narr-tools">
      <div class="narr-tools-label">${toolNames.length ? 'Tools used at this stage' : 'No tools active at this stage'}</div>
      ${allTools}
    </div>
  `;
}

function addTokens(amount) {
  const el = document.getElementById('statTokens');
  const current = parseInt(el.dataset.value || '0');
  const next = current + amount;
  el.dataset.value = next;
  el.innerHTML = `${next}<span class="unit">k</span>`;
}

function finish() {
  isPlaying = false;
  document.getElementById('btnPlay').disabled = false;
  document.getElementById('controlStatus').textContent = `Complete — case added to library`;

  // Increment library
  libraryCount++;
  document.getElementById('statLibrary').innerHTML = `${libraryCount}<span class="unit">precedents</span>`;

  // Add to cumulative bill
  const billNum = parseInt(activeCase.bill.replace(/[€k]/g, ''));
  cumulativeBill += billNum;
  document.getElementById('statBillings').innerHTML = `€${cumulativeBill}<span class="unit">k</span>`;

  // Final narrative override — show summary
  setTimeout(() => {
    const panel = document.getElementById('narrativePanel');
    panel.innerHTML = `
      <div class="narr-stage-num" style="color:var(--green);">✓ Complete · ${activeCase.ref}</div>
      <div class="narr-stage-title">Case fulfilled</div>
      <div class="narr-stage-arch">${activeCase.title}</div>
      <div class="narr-stage-body">
        <p><strong>Eleven stages run.</strong> Verification tools applied where they earned their keep — not as universal gates.</p>
        <p style="margin-top:10px;"><strong>Reuse from library:</strong> ${activeCase.reuse}% — the precedent match meaningfully reduced cost.</p>
        <p style="margin-top:10px;"><strong>Token bill:</strong> ${activeCase.bill} — itemised by stage and tool. Visible to the client. Defensible to the auditor.</p>
        <p style="margin-top:10px;"><strong>Library entry:</strong> recorded as a new precedent. The next similar request will reuse from this case.</p>
        <p style="margin-top:14px; font-style:italic; color:var(--ink-mute);">Pick another case to see the architecture handle a different work type. Try an anti-case to see what the platform deliberately refuses.</p>
      </div>
    `;
  }, 500);
}

function resetAnimation() {
  if (animTimer) clearTimeout(animTimer);
  isPlaying = false;
  currentStageIdx = -1;
  document.getElementById('statTokens').dataset.value = '0';
  document.getElementById('token').setAttribute('opacity', '0');
  resetStageVisuals();
}

function resetStageVisuals() {
  document.querySelectorAll('.stage-node').forEach(g => {
    const rect = g.querySelector('.stage-rect');
    rect.setAttribute('fill', '#ffffff');
    rect.setAttribute('stroke', '#d8d2c4');
    rect.setAttribute('stroke-width', '1');
    rect.removeAttribute('stroke-dasharray');
    g.querySelectorAll('text').forEach(t => {
      if (t.classList.contains('stage-info')) t.setAttribute('fill', '#8a8378');
      else if (t.tagName === 'text' && t.getAttribute('font-size') === '9') t.setAttribute('fill', '#8a8378');
      else t.setAttribute('fill', '#1a1714');
    });
  });
  document.querySelectorAll('.tool-node').forEach(g => {
    const rect = g.querySelector('.tool-rect');
    const label = g.querySelector('.tool-label');
    rect.setAttribute('fill', '#f1ede5');
    rect.setAttribute('stroke', '#d8d2c4');
    label.setAttribute('fill', '#4a443c');
  });
}

/* ===========================================================
   STAGE MODAL
   =========================================================== */

function openStageModal(stage) {
  document.getElementById('modalEyebrow').textContent = `Stage ${stage.num}`;
  document.getElementById('modalTitle').textContent = stage.label;
  document.getElementById('modalWhat').innerHTML = stage.what;
  document.getElementById('modalWhy').innerHTML = stage.why;
  document.getElementById('modalDelta').innerHTML = stage.delta;
  document.getElementById('modal').classList.add('open');
}

document.getElementById('modalClose').addEventListener('click', () => {
  document.getElementById('modal').classList.remove('open');
});
document.getElementById('modal').addEventListener('click', (e) => {
  if (e.target.id === 'modal') document.getElementById('modal').classList.remove('open');
});

