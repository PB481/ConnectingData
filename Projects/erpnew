   INIT
   =========================================================== */

document.getElementById('btnPlay').addEventListener('click', play);
document.getElementById('btnReset').addEventListener('click', () => {
  resetAnimation();
  document.querySelectorAll('.case-card').forEach(el => el.classList.remove('active'));
  activeCase = null;
  document.getElementById('btnPlay').disabled = true;
  document.getElementById('controlStatus').textContent = 'Select a case to begin';
  document.getElementById('flowTitle').textContent = 'The eleven-stage flow';
  document.getElementById('flowMeta').textContent = 'awaiting case selection';
  document.getElementById('statTokens').innerHTML = `0<span class="unit">k</span>`;
  document.getElementById('statTokensDetail').textContent = '— bills at completion';
  document.getElementById('statReuse').innerHTML = `0<span class="unit">%</span>`;
  document.getElementById('statReuseDetail').textContent = 'precedent match strength';

  const panel = document.getElementById('narrativePanel');
  panel.innerHTML = `
    <div class="narr-empty">
      <div class="narr-empty-icon">¶</div>
      <div class="narr-empty-text">The case-by-stage commentary will appear here as the flow runs.</div>
    </div>
  `;
});

buildCaseCards();
buildFlowSvg();

</script>

