  const panel = document.getElementById('narrativePanel');
  panel.innerHTML = `
    <div class="narr-stage-num">${c.ref} · ${c.tag}</div>
    <div class="narr-stage-title">${c.title}</div>
    <div class="narr-stage-arch">${c.summary}</div>
    <div class="narr-stage-body">
      Press <strong>▶ Run flow</strong> to watch the change request move through the eleven stages.
      Side commentary will update at each stage. Verification tools light up only when actually used —
      proving the architecture's "tools as needed, not pipeline gates" principle.
    </div>
    <div class="narr-tools">
      <div class="narr-tools-label">Token bill at completion</div>
      <div class="narr-tool" style="font-size:13px; padding:6px 12px;">${c.bill}</div>
    </div>
  `;
}

function selectAntiCase(c) {
  resetAnimation();
  activeCase = null;

  document.querySelectorAll('.case-card').forEach(el => el.classList.remove('active'));
  document.querySelector(`[data-case-id="${c.id}"]`).classList.add('active');

  document.getElementById('flowTitle').textContent = `${c.title} — refused at intake`;
  document.getElementById('flowMeta').textContent = `${c.ref} · scope discipline in action`;
  document.getElementById('controlStatus').textContent = `Anti-case loaded — flow does not run`;
  document.getElementById('btnPlay').disabled = true;

  // Reset stage visuals; mark intake as "rejected"
  resetStageVisuals();
  const intakeNode = document.querySelector('[data-stage-id="intake"] .stage-rect');
  if (intakeNode) {
    intakeNode.setAttribute('fill', '#fdf3ec');
    intakeNode.setAttribute('stroke', '#a85a1f');
    intakeNode.setAttribute('stroke-width', '2');
  }

  // Stats
  document.getElementById('statTokens').innerHTML = `—`;
  document.getElementById('statTokensDetail').textContent = c.bill;
  document.getElementById('statReuse').innerHTML = `—`;
