<script>
/* ===========================================================
   DATA — eleven stages, eight cases, three anti-cases
   =========================================================== */

const STAGES = [
  { id:'intake', num:'01', label:'Intake', short:'Intake',
    what:'Receive the change request. Parse it from email / portal / call into a structured representation: which fund, which share class, which jurisdiction, which regulations apply, what the deadline is, what the commercial sensitivity is.',
    why:'Real client requests come in as messy informal artefacts. Without a serious intake stage, the platform is a back-end with no front door.',
    delta:'New stage. The original architecture had no intake — it assumed structured input arrived from somewhere. Real fund admin doesn\'t work that way.'
  },
  { id:'scope', num:'02', label:'Scope & precedent', short:'Scope',
    what:'Search the case library for similar prior work. If a strong precedent exists, the bulk of the work becomes reuse plus delta. If not, this is a new case that will eventually become a precedent itself.',
    why:'This is where the case library compounds. Every fulfilled request reduces the cost of every similar future request. This is the actual moat — the verification stack is just the quality control around it.',
    delta:'Reframed. The original "novelty check" pointed at this but framed it backwards (flag the unprecedented). The right framing is precedent-first: search and reuse, novelty is implicit.'
  },
  { id:'draft', num:'03', label:'Draft', short:'Draft',
    what:'Generate the artefacts the change requires. Often multiple — calculation code, regulatory mapping, configuration, prospectus disclosure language, board memo, investor statement template. LLM does the heavy lifting here.',
    why:'Most change requests produce multiple artefacts, not just one calculation. The original architecture\'s "Builder" stage assumed code-only output.',
