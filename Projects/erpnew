  svg.appendChild(pipePath);

  // Stages
  STAGES.forEach((stage, i) => {
    const pos = STAGE_POSITIONS[i];
    const g = svgEl('g', { class:'stage-node', 'data-stage-id': stage.id, transform:`translate(${pos.x},${pos.y})` });
    g.style.cursor = 'pointer';

    // Background pill
    const rect = svgEl('rect', {
      x: -55, y: -28, width: 110, height: 56, rx: 6, ry: 6,
      fill: '#ffffff', stroke:'#d8d2c4', 'stroke-width':'1',
      class:'stage-rect'
    });
    g.appendChild(rect);

    // Stage number
    const num = svgEl('text', {
      x: -47, y: -12,
      'font-family':"'JetBrains Mono', monospace",
      'font-size':'9', fill:'#8a8378', 'letter-spacing':'1'
    });
    num.textContent = stage.num;
    g.appendChild(num);

    // Info icon
    const info = svgEl('text', {
      x: 47, y: -12, 'text-anchor':'end',
      'font-family':"'JetBrains Mono', monospace",
      'font-size':'11', fill:'#8a8378',
      class:'stage-info', cursor:'pointer'
    });
    info.textContent = '?';
    info.addEventListener('click', (e) => { e.stopPropagation(); openStageModal(stage); });
    g.appendChild(info);

    // Stage label
    const label = svgEl('text', {
      x: 0, y: 6, 'text-anchor':'middle',
      'font-family':"'Fraunces', serif",
      'font-size':'13', fill:'#1a1714', 'font-weight':'600'
    });
    label.textContent = stage.short;
    g.appendChild(label);

    // Hover open modal
    g.addEventListener('click', () => openStageModal(stage));

    svg.appendChild(g);
  });

  // Token glyph (initially hidden)
  const token = svgEl('g', { id:'token', opacity: 0 });
  const tokenCircle = svgEl('circle', {
    cx: 0, cy: 0, r: 14, fill:'#7a2418', stroke:'#faf7f2', 'stroke-width':'3'
  });
  const tokenText = svgEl('text', {
    x: 0, y: 4, 'text-anchor':'middle',
    'font-family':"'JetBrains Mono', monospace",
    'font-size':'10', fill:'#faf7f2', 'font-weight':'600'
  });
  tokenText.textContent = '◆';
  token.appendChild(tokenCircle);
  token.appendChild(tokenText);
  svg.appendChild(token);

  // Verification tools — orbital cluster
  TOOL_POSITIONS.forEach(t => {
    const tool = TOOLS.find(tl => tl.id === t.id);
    const g = svgEl('g', { class:'tool-node', 'data-tool-id': t.id, transform:`translate(${t.x},${t.y})` });

    const rect = svgEl('rect', {
      x: -38, y: -9, width: 76, height: 18, rx: 9, ry: 9,
      fill: '#f1ede5', stroke:'#d8d2c4', 'stroke-width':'1',
      class:'tool-rect'
    });
    g.appendChild(rect);

    const label = svgEl('text', {
      x: 0, y: 3, 'text-anchor':'middle',
      'font-family':"'JetBrains Mono', monospace",
      'font-size':'9', fill:'#4a443c', 'letter-spacing':'0.5',
      class:'tool-label'
    });
    label.textContent = tool.label.toUpperCase();
    g.appendChild(label);

    svg.appendChild(g);
  });
}

function buildPipelinePath() {
  let d = `M ${STAGE_POSITIONS[0].x} ${STAGE_POSITIONS[0].y}`;
  // Stages 1-6 horizontal
  for (let i = 1; i < 6; i++) {
    d += ` L ${STAGE_POSITIONS[i].x} ${STAGE_POSITIONS[i].y}`;
  }
  // Curve down to row 2
  d += ` L ${STAGE_POSITIONS[6].x} ${STAGE_POSITIONS[6].y}`;
  // Stages 7-11 horizontal (right to left)
  for (let i = 7; i < 11; i++) {
    d += ` L ${STAGE_POSITIONS[i].x} ${STAGE_POSITIONS[i].y}`;
  }
  return d;
}

function svgEl(name, attrs = {}) {
  const el = document.createElementNS('http://www.w3.org/2000/svg', name);
  Object.entries(attrs).forEach(([k, v]) => {
    if (k === 'class') el.setAttribute('class', v);
    else el.setAttribute(k, v);
  });
  return el;
}

/* ===========================================================
   CASE SELECTION
   =========================================================== */

function selectCase(c) {
  resetAnimation();
  activeCase = c;

  // Card highlights
  document.querySelectorAll('.case-card').forEach(el => el.classList.remove('active'));
  document.querySelector(`[data-case-id="${c.id}"]`).classList.add('active');

  // Title + meta
  document.getElementById('flowTitle').textContent = c.title;
  document.getElementById('flowMeta').textContent = `${c.ref} · ${c.tag} · ready to run`;
  document.getElementById('controlStatus').textContent = `Loaded: ${c.title}`;
  document.getElementById('btnPlay').disabled = false;

  // Reset stage visuals to default
  resetStageVisuals();

  // Reset stats
  document.getElementById('statTokens').innerHTML = `0<span class="unit">k</span>`;
  document.getElementById('statTokensDetail').textContent = `bill estimate: ${c.bill}`;
  document.getElementById('statReuse').innerHTML = `${c.reuse}<span class="unit">%</span>`;
