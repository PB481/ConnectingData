function monthsSince(d){if(!d)return 0;const a=new Date(d),n=new Date();return(n.getFullYear()-a.getFullYear())*12+(n.getMonth()-a.getMonth())}
function todayISO(){return new Date().toISOString().slice(0,10)}
function fmtDate(){return new Date().toLocaleDateString(‘en-IE’,{weekday:‘long’,year:‘numeric’,month:‘long’,day:‘numeric’})}
function load(k){try{const s=localStorage.getItem(‘cc_’+k);return s?JSON.parse(s):JSON.parse(JSON.stringify(DEFAULTS[k]))}catch{return JSON.parse(JSON.stringify(DEFAULTS[k]))}}
function save(k,d){try{localStorage.setItem(‘cc_’+k,JSON.stringify(d))}catch{}}
function exportAll(){const b={};DATA_KEYS.forEach(k=>b[k]=load(k));b._exported=new Date().toISOString();b.*version=‘2.1’;const bl=new Blob([JSON.stringify(b,null,2)],{type:‘application/json’});const a=document.createElement(‘a’);a.href=URL.createObjectURL(bl);a.download=’command-center-data*’+todayISO()+’.json’;a.click();URL.revokeObjectURL(a.href);showToast()}
function importFile(file){const r=new FileReader();r.onload=e=>{try{const b=JSON.parse(e.target.result);DATA_KEYS.forEach(k=>{if(b[k])save(k,b[k])});alert(‘Data imported. Page will reload.’);location.reload()}catch(err){alert(’Import failed: ’+err.message)}};r.readAsText(file)}

