<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Product Manager Command Center</title>
<style>
/* ═══════════════════════════════════════════════════════════════════════════════
   DESIGN SYSTEM — LIGHT THEME — ZERO DEPENDENCIES
   ═══════════════════════════════════════════════════════════════════════════════ */
:root {
  --bg-page:#f4f5f7;--bg-surface:#fff;--bg-inset:#f8f9fb;--bg-hover:#f0f1f4;--bg-active:#e8eaf0;
  --border:#e2e4ea;--border-light:#ecedf1;--border-focus:#4a7cfa;
  --text-primary:#1a1e2c;--text-secondary:#5c6274;--text-tertiary:#8b90a0;--text-muted:#b0b4c0;
  --blue:#4a7cfa;--blue-bg:#eef3ff;--blue-border:#c5d5fc;
  --green:#22a06b;--green-bg:#e6f9f0;--green-border:#a1e6c8;
  --red:#de350b;--red-bg:#ffedeb;--red-border:#f8b4b4;
  --yellow:#d97706;--yellow-bg:#fef9ec;--yellow-border:#fcd88e;
  --purple:#7c5cfc;--purple-bg:#f3f0ff;
  --font-sans:'Segoe UI',system-ui,-apple-system,sans-serif;
  --font-mono:'Consolas','Courier New',monospace;
  --radius:8px;--radius-sm:5px;--sidebar-w:250px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{font-family:var(--font-sans);font-size:13.5px;line-height:1.6;color:var(--text-primary);background:var(--bg-page);-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:6px;height:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
input[type=number]::-webkit-inner-spin-button,input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none}input[type=number]{-moz-appearance:textfield}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
@keyframes toastIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.fade-in{animation:fadeIn .2s ease}

/* Layout */
.app-shell{display:flex;min-height:100vh}
.sidebar{width:var(–sidebar-w);background:var(–bg-surface);border-right:1px solid var(–border);display:flex;flex-direction:column;flex-shrink:0;transition:width .3s ease;overflow:hidden}
.sidebar.collapsed{width:0;border-right:none}
.main-area{flex:1;display:flex;flex-direction:column;min-width:0;overflow:auto}
.sidebar-logo{padding:20px 20px 16px;border-bottom:1px solid var(–border)}
.sidebar-logo h1{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(–blue);margin-bottom:2px}
.sidebar-logo p{font-size:10px;color:var(–text-tertiary);letter-spacing:.06em}
.sidebar-nav{padding:10px 8px;flex:1}
.sidebar-footer{padding:10px 12px;border-top:1px solid var(–border)}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:var(–radius-sm);cursor:pointer;font-size:12.5px;font-weight:500;transition:all .15s;color:var(–text-secondary);border:1px solid transparent;margin-bottom:2px}
.nav-item:hover{background:var(–bg-hover);color:var(–text-primary)}
.nav-item.active{background:var(–blue-bg);color:var(–blue);font-weight:600;border-color:var(–blue-border)}
.nav-item svg{width:16px;height:16px;flex-shrink:0}
.top-bar{display:flex;align-items:center;gap:14px;padding:14px 24px;border-bottom:1px solid var(–border);background:var(–bg-surface);flex-shrink:0}
.top-bar-title{font-size:14px;font-weight:700;color:var(–text-primary)}
.top-bar-date{margin-left:auto;font-size:11px;color:var(–text-tertiary)}
.metrics-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:12px;padding:16px 24px;flex-shrink:0}
.content-area{flex:1;padding:20px 24px;overflow:auto}

/* Components */
.card{background:var(–bg-surface);border:1px solid var(–border);border-radius:var(–radius);padding:20px;margin-bottom:14px}
.card-inset{background:var(–bg-inset);border:1px solid var(–border-light);border-radius:var(–radius-sm);padding:12px 14px}
.metric-card{background:var(–bg-surface);border:1px solid var(–border);border-radius:var(–radius);padding:14px 16px;border-left:3px solid var(–blue)}
.metric-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(–text-tertiary);margin-bottom:4px;display:flex;align-items:center;gap:5px}
.metric-value{font-size:22px;font-weight:700;font-family:var(–font-mono)}
.section-title{font-size:14px;font-weight:700;color:var(–text-primary);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.section-title svg{width:17px;height:17px}
.input,.textarea{background:var(–bg-surface);border:1px solid var(–border);border-radius:var(–radius-sm);padding:7px 10px;color:var(–text-primary);font-size:12.5px;font-family:var(–font-sans);outline:none;transition:border-color .15s}
.input:focus,.textarea:focus{border-color:var(–border-focus);box-shadow:0 0 0 2px #4a7cfa18}
.input{width:100%}select.input{cursor:pointer}
.textarea{width:100%;min-height:120px;resize:vertical;line-height:1.65}
.tbl{width:100%;border-collapse:separate;border-spacing:0}
.tbl th{text-align:left;padding:8px 12px;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(–text-tertiary);border-bottom:2px solid var(–border)}
.tbl td{padding:10px 12px;border-bottom:1px solid var(–border-light);font-size:12.5px;vertical-align:middle}
.tbl tbody tr:hover{background:var(–bg-hover)}
.badge{display:inline-block;padding:2px 10px;border-radius:10px;font-size:10px;font-weight:700;letter-spacing:.04em;text-transform:uppercase}
.badge-red{background:var(–red-bg);color:var(–red);border:1px solid var(–red-border)}
.badge-yellow{background:var(–yellow-bg);color:var(–yellow);border:1px solid var(–yellow-border)}
.badge-green{background:var(–green-bg);color:var(–green);border:1px solid var(–green-border)}
.badge-blue{background:var(–blue-bg);color:var(–blue);border:1px solid var(–blue-border)}
.tag{display:inline-flex;align-items:center;padding:4px 12px;border-radius:14px;font-size:11px;font-weight:600;cursor:pointer;transition:all .15s;border:1px solid var(–border);color:var(–text-secondary);background:transparent}
.tag:hover{border-color:var(–text-muted)}.tag.active{background:var(–blue-bg);color:var(–blue);border-color:var(–blue-border)}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:var(–radius-sm);font-size:11.5px;font-weight:600;font-family:var(–font-sans);cursor:pointer;transition:all .15s;border:1px solid transparent}
.btn svg{width:13px;height:13px}
.btn-primary{background:var(–blue);color:#fff}.btn-primary:hover{background:#3a6ae8}
.btn-ghost{background:transparent;color:var(–text-secondary);border-color:var(–border)}.btn-ghost:hover{background:var(–bg-hover);color:var(–text-primary)}
.toggle-btn{background:none;border:none;cursor:pointer;padding:4px;color:var(–text-secondary)}.toggle-btn:hover{color:var(–text-primary)}.toggle-btn svg{width:18px;height:18px}
.toast{position:fixed;bottom:24px;right:24px;background:var(–green-bg);color:var(–green);padding:10px 18px;border-radius:var(–radius);font-size:12px;font-weight:600;z-index:9999;border:1px solid var(–green-border);box-shadow:0 8px 32px rgba(0,0,0,.08);animation:toastIn .3s ease;display:none;align-items:center;gap:6px}
.toast.show{display:flex}
.reset-link{font-size:10px;color:var(–text-muted);cursor:pointer;border:none;background:none;font-family:var(–font-sans)}.reset-link:hover{color:var(–red)}
@media(max-width:860px){.sidebar{position:fixed;z-index:100;height:100vh;box-shadow:4px 0 24px rgba(0,0,0,.08)}.sidebar.collapsed{box-shadow:none}.grid-2{grid-template-columns:1fr!important}}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.grid-4{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px}
.flex-wrap-gap{display:flex;flex-wrap:wrap;gap:8px}
.overflow-x{overflow-x:auto}
.text-right{text-align:right}.text-sm{font-size:12px}.text-xs{font-size:11px}.text-mono{font-family:var(–font-mono)}.font-bold{font-weight:700}.font-semi{font-weight:600}
.color-red{color:var(–red)}.color-green{color:var(–green)}.color-yellow{color:var(–yellow)}.color-blue{color:var(–blue)}.color-purple{color:var(–purple)}.color-muted{color:var(–text-tertiary)}
.progress-track{height:6px;background:var(–bg-active);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;border-radius:3px;transition:width .3s ease}
.stage-tag{display:inline-flex;padding:3px 11px;border-radius:12px;font-size:11px;font-weight:600}
.stage-onboarding{background:var(–blue-bg);color:var(–blue)}.stage-launch{background:var(–green-bg);color:var(–green)}.stage-liquidation{background:var(–red-bg);color:var(–red)}
.stage-prospect{background:#f3f0ff;color:var(–purple)}.stage-proposal{background:var(–blue-bg);color:var(–blue)}.stage-negotiation{background:var(–yellow-bg);color:var(–yellow)}.stage-won{background:var(–green-bg);color:var(–green)}.stage-lost{background:var(–bg-active);color:var(–text-tertiary)}
.stage-research{background:#f3f0ff;color:var(–purple)}.stage-build{background:var(–blue-bg);color:var(–blue)}.stage-beta{background:var(–yellow-bg);color:var(–yellow)}.stage-live{background:var(–green-bg);color:var(–green)}.stage-retired{background:var(–bg-active);color:var(–text-tertiary)}
/* Heatmap */
.heatmap-grid{display:grid;gap:2px;font-size:10px}
.heatmap-cell{padding:6px 8px;border-radius:3px;text-align:center;font-weight:600;font-size:10px;line-height:1.3;transition:all .15s;cursor:default;position:relative}
.heatmap-cell:hover{opacity:.85;transform:scale(1.03);z-index:2}
.heatmap-cell.str-strong{background:#dcfce7;color:#166534;border:1px solid #bbf7d0}
.heatmap-cell.str-adequate{background:#fef9c3;color:#854d0e;border:1px solid #fde68a}
.heatmap-cell.str-emerging{background:#dbeafe;color:#1e40af;border:1px solid #bfdbfe}
.heatmap-cell.str-weak{background:#fee2e2;color:#991b1b;border:1px solid #fecaca}
.heatmap-header{background:var(–bg-active);color:var(–text-secondary);font-weight:700;letter-spacing:.05em;font-size:9.5px;text-transform:uppercase}
.heatmap-row-label{background:var(–bg-surface);color:var(–text-primary);font-weight:600;text-align:left!important;padding:6px 10px;border:1px solid var(–border-light);white-space:nowrap}
.legend-swatch{display:inline-block;width:14px;height:14px;border-radius:3px;vertical-align:middle;margin-right:5px}
.section-divider{border-top:2px solid var(–border);margin:24px 0 20px}
.dim-section-title{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(–text-tertiary);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.tab-section{display:none}.tab-section.active{display:block}
</style>

