L.push(’’);
L.push(‘2. SALES PIPELINE’,‘─’.repeat(40),‘Pipeline AUM: €’+pipeAum+‘m (’+activeS.length+’ active) | Weighted: €’+weightV.toFixed(0)+‘m | Won: ‘+wonS.length);
if(activeS.length){L.push(‘Active:’);activeS.forEach(r=>L.push(’  • ‘+r.prospect+’ — €’+r.aum+‘m — ‘+r.stage+’ (’+r.probability+’%)’))}
L.push(’’);
L.push(‘3. CHANGE PIPELINE’,‘─’.repeat(40),‘Projects: ‘+p.length+’ | Critical: ‘+redPipe.length+’ | Amber: ‘+yellowPipe.length);
if(redPipe.length)L.push(’  Red: ‘+redPipe.map(r=>r.project+’ [’+r.stakeholder+’]’).join(’, ‘));
L.push(’’);
L.push(‘4. RFP READINESS’,‘─’.repeat(40),‘Modules: ‘+rfp.length);
L.push(’’);
L.push(‘5. PRODUCTS’,‘─’.repeat(40),‘In dev: ‘+prodActive.length+’ | Avg progress: ‘+avgProg+’%’);
const prodHigh=prodActive.filter(r=>r.priority===‘High’);
if(prodHigh.length){L.push(‘High priority:’);prodHigh.forEach(r=>L.push(’  • ‘+r.name+’ — ‘+r.stage+’ — ‘+r.progress+’%’))}
L.push(’’);
L.push(‘6. CLIENT POSITIONING’,‘─’.repeat(40),‘Sweet spot: ‘+sweet.length+’ | Edge: ‘+edge.length+’ | Off target: ‘+off.length);
if(off.length)L.push(’  Off-target: ‘+off.map(c=>c.client).join(’, ‘));
L.push(’’);
L.push(‘7. RISK SUMMARY’,‘─’.repeat(40));
const rl=redPipe.length>2?‘HIGH’:redPipe.length>0?‘MEDIUM’:‘LOW’;
L.push(‘Overall: ‘+rl);
L.push(’’,‘═’.repeat(56),‘Generated: ‘+now.toLocaleString(‘en-IE’));
STATE.weeklyOut=L.join(’\n’);renderContent();
}

