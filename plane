.legend {
display: flex;
justify-content: center;
gap: 1.5rem;
padding: 1rem 0;
flex-wrap: wrap;
}

.legend-item {
display: flex;
align-items: center;
gap: 0.5rem;
font-size: 0.75rem;
color: var(–text-dim);
}

.legend-dot {
width: 12px; height: 12px; border-radius: 50%;
}
.legend-dot.red { background: var(–red-bright); box-shadow: 0 0 8px var(–red-glow); }
.legend-dot.amber { background: var(–amber); box-shadow: 0 0 8px var(–amber-glow); }
.legend-dot.purple { background: var(–purple); box-shadow: 0 0 8px var(–purple-glow); }

/* CARDS */
.card-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
gap: 1rem;
margin-top: 1.5rem;
}

.card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 8px;
padding: 1.25rem;
transition: all 0.25s;
cursor: default;
}
.card:hover {
border-color: #334155;
transform: translateY(-2px);
