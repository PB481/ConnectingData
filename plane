<script>
const ZONE_DATA = {
  'governance': { title: 'COCKPIT — Governance & Key-Person Risk', text: 'The fund accountant who "just knows." Pricing decisions in someone\'s head. Approval chains that exist only as convention. When this fails, it\'s total loss.', color: '#f59e0b' },
  'data-lineage': { title: 'LEFT ENGINE — Data Lineage & Source Truth', text: 'Price feeds silently switching from bid to mid. Counterparty format changes. Static data drift. By the time you see the NAV break, you\'ve been wrong for weeks.', color: '#f59e0b' },
  'regulatory': { title: 'RIGHT ENGINE — Regulatory Interpretation', text: 'AIFMD II, SFDR, CBI — technically compliant, substantively wrong. Classification logic and investment limit interpretations embedded in code nobody reviews.', color: '#f59e0b' },
  'recon-chain': { title: 'FUEL LINE — Cash & Position Recon Chain', text: 'The invisible pipeline: custodian ↔ TA ↔ accounting. Failed SWIFTs, aged settlements, accounts that reconcile to zero because both sides are wrong.', color: '#f59e0b' },
  'integration-seam': { title: 'WING ROOT (L) — Integration Seams', text: 'Where TA meets accounting meets pricing. Each works alone. The seam doesn\'t — especially on month-end, in-specie transfers, or side pocket events.', color: '#f59e0b' },
  'vendor-lock': { title: 'WING ROOT (R) — Vendor Lock-in', text: 'Your NAV logic in their proprietary format. Your reg config in their schema. When they raise prices 40% or get acquired, you don\'t have a migration path.', color: '#f59e0b' },
  'continuity': { title: 'TAIL JOIN — Operational Continuity', text: 'Three resignations in one quarter. The real BCP, not the documented one. Your outsource partner\'s outsource partner. Stability under actual stress.', color: '#f59e0b' },
  'rubber-stamp': { title: 'CREW — Rubber-Stamping / Functional Illiteracy', text: 'Reviewers approving outputs because the software has historically been correct — not because they\'ve analysed them. The human override has atrophied.', color: '#a78bfa' },
  'shadow-it': { title: 'MAINTENANCE BAY — The Excel Graveyard', text: 'Critical processes held together by macros built by one analyst. Invisible to management. Will break the moment that person takes holiday or resigns.', color: '#a78bfa' },
  'psych-safety': { title: 'COMMS — Psychological Safety / Error Culture', text: 'Low near-miss reporting in a complex environment isn\'t quality — it\'s fear. Staff are covering errors, not reporting them. The most Wald-like signal of all.', color: '#a78bfa' },
  'burnout': { title: 'EXHAUST — Data Pipeline Burnout', text: 'Highly paid accounting staff spending hours cleaning messy data. The best people leave. The people who stay stop questioning. The canary dies quietly.', color: '#a78bfa' },
  'why-gap': { title: 'NECK — The "Why" Gap / Institutional Memory', text: 'Can your team manually audit a complex performance fee waterfall without the platform? If automation removed the knowledge, the safety net has a hole.', color: '#a78bfa' }
};

const tooltip = document.getElementById('tooltip');

document.querySelectorAll('.fatal-zone').forEach(zone => {
  const key = zone.dataset.zone;
  const data = ZONE_DATA[key];
  if (!data) return;

  zone.addEventListener('mouseenter', () => {
    tooltip.innerHTML = '<div class="tooltip-title" style="color:' + data.color + ';">' + data.title + '</div>' + data.text;
    tooltip.classList.add('show');
  });

  zone.addEventListener('mousemove', (e) => {
    const wrap = document.querySelector('.diagram-wrap');
    const rect = wrap.getBoundingClientRect();
    let x = e.clientX - rect.left + 15;
    let y = e.clientY - rect.top - 10;
    if (x + 270 > rect.width) x = e.clientX - rect.left - 275;
    if (y + 120 > rect.height) y = y - 100;
    tooltip.style.left = x + 'px';
    tooltip.style.top = y + 'px';
  });

  zone.addEventListener('mouseleave', () => {
    tooltip.classList.remove('show');
  });

  zone.addEventListener('touchstart', (e) => {
    e.preventDefault();
    const touch = e.touches[0];
    const wrap = document.querySelector('.diagram-wrap');
    const rect = wrap.getBoundingClientRect();
    tooltip.innerHTML = '<div class="tooltip-title" style="color:' + data.color + ';">' + data.title + '</div>' + data.text;
    tooltip.style.left = (touch.clientX - rect.left - 130) + 'px';
    tooltip.style.top = (touch.clientY - rect.top - 120) + 'px';
    tooltip.classList.add('show');
    setTimeout(() => tooltip.classList.remove('show'), 3000);
  });
});

function showTab(name, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  btn.classList.add('active');
}
</script>

