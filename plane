font-size: 1.05rem;
line-height: 1.6;
color: var(–text);
}

.wald-quote cite {
display: block;
margin-top: 0.5rem;
font-size: 0.8rem;
color: var(–text-dim);
font-style: normal;
font-family: ‘IBM Plex Mono’, monospace;
