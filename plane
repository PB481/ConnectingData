}

/* TABS */
.tab-bar {
display: flex;
justify-content: center;
gap: 0.25rem;
padding: 1.5rem 1rem 0;
flex-wrap: wrap;
}

.tab-btn {
background: var(–surface);
border: 1px solid var(–border);
color: var(–text-dim);
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.7rem;
padding: 0.5rem 0.85rem;
cursor: pointer;
border-radius: 4px 4px 0 0;
transition: all 0.2s;
text-transform: uppercase;
letter-spacing: 0.08em;
}

.tab-btn:hover { color: var(–text); background: var(–surface2); }
.tab-btn.active {
background: var(–surface2);
color: #fff;
border-bottom-color: var(–surface2);
}
.tab-btn.active[data-color=“red”] { border-top: 2px solid var(–red-bright); }
.tab-btn.active[data-color=“amber”] { border-top: 2px solid var(–amber); }
.tab-btn.active[data-color=“purple”] { border-top: 2px solid var(–purple); }
.tab-btn.active[data-color=“rose”] { border-top: 2px solid var(–rose); }
.tab-btn.active[data-color=“teal”] { border-top: 2px solid var(–teal); }

/* MAIN */
.container {
max-width: 1100px;
margin: 0 auto;
padding: 0 1rem 3rem;
}

.panel {
display: none;
animation: fadeIn 0.4s ease;
}
.panel.active { display: block; }

@keyframes fadeIn {
from { opacity:0; transform: translateY(8px); }
to { opacity:1; transform: translateY(0); }
}

/* DIAGRAM */
.diagram-wrap {
position: relative;
max-width: 800px;
margin: 2rem auto;
}

.diagram-svg-container {
width: 100%;
aspect-ratio: 5/4;
position: relative;
}

.diagram-svg-container svg {
width: 100%;
height: 100%;
}

