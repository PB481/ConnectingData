.section-header .bar.red { background: var(–red-bright); }
.section-header .bar.amber { background: var(–amber); }
.section-header .bar.purple { background: var(–purple); }
.section-header .bar.teal { background: var(–teal); }
.section-header .bar.rose { background: var(–rose); }

